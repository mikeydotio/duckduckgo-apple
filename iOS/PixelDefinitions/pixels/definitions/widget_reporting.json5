// See https://app.asana.com/1/137249556945/project/392891325557410/task/1210882421460693
{
    "m_widget-report": {
        "description": "Fires daily to report configured widgets on the device, including widget kinds and families. This pixel can be enabled and disabled using the iOSBrowserConfig.widgetReporting feature flag which is off by default.",
        "owners": ["brindy"],
        "triggers": ["startup"],
        "suffixes": ["platform", "form_factor"],
        "parameters": [
            "appVersion",
            {
                "key": "enabled_widgets",
                "description": "A comma separated list of enabled widgets in the format WidgetName-Family. The widget name is defined statically in code so will not contain user inforation.  The family is defined by iOS",
                "type": "string",
                "pattern": "([A-Za-z]+-(systemSmall|systemMedium|systemLarge|accessoryCircular))(,[A-Za-z]+-(systemSmall|systemMedium|systemLarge|accessoryCircular))*",
                "examples": [
                    "QuickActionWidget-systemSmall",
                    "QuickActionWidget-systemSmall,FavoritesWidget-systemLarge",
                    "VPNStatusWidget-systemSmall,QuickActionsWidget-systemSmall,FavoritesWidget-systemMedium,FavoritesWidget-systemLarge"
                ]
            },
            {
                "key": "privacy_config_embedded_etag",
                "description": "ETag of the privacy configuration bundled with the app, or 'none' if unavailable",
                "type": "string"
            },
            {
                "key": "privacy_config_fetched_etag",
                "description": "ETag of the remotely fetched privacy configuration, or 'none' if unavailable",
                "type": "string"
            },
            {
                "key": "current_etag",
                "description": "Identifier of the privacy configuration currently in use",
                "type": "string"
            },
            {
                "key": "is_internal",
                "description": "Whether the user is flagged as an internal user",
                "type": "boolean"
            },
            {
                "key": "feature_state_enabled",
                "description": "Whether the widgetReporting subfeature is enabled in the current privacy configuration",
                "type": "boolean"
            }
        ]
    },
    "m_widget-report-failure": {
        "description": "Fires when widget configuration reporting fails due to an error retrieving current widget configurations. This pixel can be enabled and disabled using the iOSBrowserConfig.widgetReporting feature flag which is off by default.",
        "owners": ["brindy"],
        "triggers": ["startup"],
        "suffixes": ["platform", "form_factor"],
        "parameters": ["appVersion", "errorCode", "errorDomain", "underlyingErrorCode", "underlyingErrorDomain"]
    }
}
