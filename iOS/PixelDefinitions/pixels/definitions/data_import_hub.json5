                "type": "string",
                "description": "Raw exporter identifier from the iOS credential hand-off payload",
                "examples": ["apple.com", "com.google.chrome", "unknown"]
            },
            {
                "key": "saved_credentials",
                "type": "string",
                "description": "Bucketed count of imported credentials"
            }
        ]
    },
