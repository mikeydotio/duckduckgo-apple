        "description": "Fired when DDG receives a credential-exchange hand-off activity",
        "owners": ["amddg44"],
        "triggers": ["other"],
        "suffixes": ["platform", "form_factor"],
        "parameters": [
            "appVersion",
            {
                "key": "source",
