        ],
        "parameters": ["appVersion"]
    },
    "m_web_extension_dark_reader_disabled": {
        "description": "Fires when the user disables the Dark Reader extension in settings.",
        "owners": ["dus7"],
        "triggers": ["other"],
        "suffixes": [
            ["daily", "platform", "form_factor"],
