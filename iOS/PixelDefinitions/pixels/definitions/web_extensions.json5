        ]
    },
    "m_web_extension_dark_reader_install_error": {
        "description": "Fires when installing or upgrading the embedded (bundled) Dark Reader extension fails.",
        "owners": ["dus7"],
        "triggers": ["exception"],
        "suffixes": [
            ["daily", "platform", "form_factor"],
