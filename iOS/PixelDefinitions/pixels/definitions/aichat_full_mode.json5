// Full Duck.ai mode pixels for sidebar and settings menu interactions
{
    "m_aichat_fire_button_tapped": {
        "description": "Fires when user taps the fire button while in full Duck.ai mode",
        "owners": ["aataraxiaa"],
        "triggers": ["other"],
        "suffixes": ["first_daily_count", "platform", "form_factor"],
        "parameters": ["appVersion"]
    },
    "m_aichat_omnibar_sidebar_button_tapped": {
        "description": "Fires when user taps the sidebar button in the omnibar while in full Duck.ai mode",
        "owners": ["aataraxiaa"],
        "triggers": ["other"],
        "suffixes": ["first_daily_count", "platform", "form_factor"],
        "parameters": ["appVersion"]
    },
    "m_aichat_omnibar_new_chat_button_tapped": {
        "description": "Fires when user taps the new chat button in the omnibar while in full Duck.ai mode",
        "owners": ["aataraxiaa"],
        "triggers": ["other"],
        "suffixes": ["first_daily_count", "platform", "form_factor"],
        "parameters": ["appVersion"]
    },
    "m_aichat_settings_menu_opened": {
        "description": "Fires when user opens the Duck.ai settings menu",
        "owners": ["aataraxiaa"],
        "triggers": ["other"],
        "suffixes": ["first_daily_count", "platform", "form_factor"],
        "parameters": ["appVersion"]
    },
    "m_aichat_settings_menu_sidebar_tapped": {
        "description": "Fires when user taps the sidebar option in the Duck.ai settings menu",
        "owners": ["aataraxiaa"],
        "triggers": ["other"],
        "suffixes": ["first_daily_count", "platform", "form_factor"],
        "parameters": ["appVersion"]
    },
    "m_aichat_settings_menu_aichat_settings_tapped": {
        "description": "Fires when user taps the AI Chat settings option in the Duck.ai settings menu",
        "owners": ["aataraxiaa"],
        "triggers": ["other"],
        "suffixes": ["first_daily_count", "platform", "form_factor"],
        "parameters": ["appVersion"]
    },
    "m_aichat_settings_menu_new_chat_tab_tapped": {
        "description": "Fires when user taps the new chat tab option in the Duck.ai settings menu",
        "owners": ["aataraxiaa"],
        "triggers": ["other"],
        "suffixes": ["first_daily_count", "platform", "form_factor"],
        "parameters": ["appVersion"]
    },
    "m_aichat_tab_switcher_opened": {
        "description": "Fires when user opens the tab switcher while in full Duck.ai mode",
        "owners": ["aataraxiaa"],
        "triggers": ["other"],
        "suffixes": ["first_daily_count", "platform", "form_factor"],
        "parameters": ["appVersion"]
    },
    "m_aichat_tab_did_terminate": {
        "description": "Fires when a Duck.ai tab's WebKit web content process terminates",
        "owners": ["aataraxiaa", "Bunn", "samsymons"],
        "triggers": ["exception"],
        "suffixes": ["first_daily_count", "platform", "form_factor"],
        "parameters": ["appVersion"]
    },
    "m_aichat_tab_did_reload_after_terminate": {
        "description": "Fires when a foreground Duck.ai tab is automatically reloaded after its WebKit web content process terminated - the user-impact signal. Daily counts users affected; count tracks reload volume, where a spike relative to the daily indicates a renderer crash loop (terminate -> auto-reload -> terminate).",
        "owners": ["aataraxiaa", "Bunn", "samsymons"],
        "triggers": ["exception"],
        "suffixes": ["first_daily_count", "platform", "form_factor"],
        "parameters": ["appVersion"]
    },
    "m_aichat_tab_terminated_": {
        "description": "Fires when a Duck.ai tab's WebKit web content process terminates, with the WebKit termination reason in the pixel name.",
        "owners": ["aataraxiaa", "Bunn", "samsymons"],
        "triggers": ["exception"],
        "suffixes": [
            {
                "description": "WebKit web content process termination reason",
                "enum": [
                    "exceeded_memory_limit",
                    "exceeded_cpu_limit",
                    "requested_by_client",
                    "crash",
                    "exceeded_shared_process_crash_limit",
                    "unknown"
                ]
            },
            "first_daily_count",
            "platform",
            "form_factor"
        ],
        "parameters": ["appVersion"]
    },
    "m_aichat_recent_chat_selected_pinned": {
        "description": "Fired when user selects a pinned recent chat from the suggestions list",
        "owners": ["Bunn"],
        "triggers": ["other"],
        "suffixes": ["first_daily_count", "platform", "form_factor"],
        "parameters": ["appVersion"]
    },
    "m_aichat_recent_chat_selected": {
        "description": "Fired when user selects a non-pinned recent chat from the suggestions list",
        "owners": ["Bunn"],
        "triggers": ["other"],
        "suffixes": ["first_daily_count", "platform", "form_factor"],
        "parameters": ["appVersion"]
    },
    "m_aichat_recent_chat_delete_button_tapped": {
        "description": "Fired when user taps the delete (fire) icon on a recent chat row in the Duck.ai suggestions list",
        "owners": ["jleandroperez"],
        "triggers": ["other"],
        "suffixes": ["first_daily_count", "platform", "form_factor"],
        "parameters": ["appVersion"]
    },
    "m_aichat_recent_chat_delete_confirmed": {
        "description": "Fired when user confirms deletion of a recent chat from the Duck.ai suggestions list",
        "owners": ["jleandroperez"],
        "triggers": ["other"],
        "suffixes": ["first_daily_count", "platform", "form_factor"],
        "parameters": ["appVersion"]
    },
    "m_aichat_recent_chat_delete_cancelled": {
        "description": "Fired when user cancels deletion of a recent chat from the Duck.ai suggestions list",
        "owners": ["jleandroperez"],
        "triggers": ["other"],
        "suffixes": ["first_daily_count", "platform", "form_factor"],
        "parameters": ["appVersion"]
    }
}
