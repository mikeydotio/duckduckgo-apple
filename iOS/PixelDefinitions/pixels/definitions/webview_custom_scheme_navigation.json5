{
    "m_webview_external-scheme-navigation_safari-redirect_load-url-requested": {
        "description": "Fires when a converted Safari redirect URL load is requested in the web view",
        "owners": ["dus7", "brindy"],
        "triggers": ["other"],
        "suffixes": ["first_daily_count", "platform", "form_factor"],
        "parameters": ["appVersion"]
    },
    "m_webview_external-scheme-navigation_safari-redirect-loop_error-page-shown": {
        "description": "Fires showing the error page for the redirect loop (detection doesn't always mean we show this page)",
        "owners": ["dus7", "brindy"],
        "triggers": ["other"],
        "suffixes": ["first_daily_count", "platform", "form_factor"],
        "parameters": ["appVersion"]
    }
}
