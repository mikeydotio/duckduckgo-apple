{
    // This file defines pixels sent by the native experiments framework
    "defaultSuffixes": [],
    "activeExperiments": {
        "onboardingDismissExperiment": {
            "cohorts": ["control", "variant1", "variant2"],
            "metrics": {
                "save_tap": {
                    "description": "Fires once per user when they tap Save on the autofill onboarding prompt",
                    "enum": ["1"]
                },
                "dismiss_tap": {
                    "description": "Fires each time the user dismisses the autofill onboarding prompt",
                    "enum": ["1"]
                },
                "never_ask_tap": {
                    "description": "Fires at various thresholds when the user taps Never ask for this site",
                    "enum": ["1", "2", "3", "5"]
                },
                "passwords_saved": {
                    "description": "Fires on each password save with the current account count bucket",
                    "enum": ["none", "few", "some", "many", "lots"]
                },
                "import_completed": {
                    "description": "Fires when the user completes the data import flow",
                    "enum": ["1"]
                },
                "autofill_enabled": {
                    "description": "Fires when the user enables or disables autofill",
                    "type": "boolean"
                },
                "sync_enabled": {
                    "description": "Fires when the user enables or disables sync",
                    "type": "boolean"
                },
                "autofill_other_apps_enabled": {
                    "description": "Fires when the user enables or disables Autofill in Other Apps (autofill provider extension)",
                    "type": "boolean"
                },
                "impression_count": {
                    "description": "Bucketed number of onboarding prompt impressions before the user saved",
                    "enum": ["1", "2-3", "4-6", "7-10", "11+"]
                },
                "days_to_conversion": {
                    "description": "Bucketed number of days between experiment enrollment and first save",
                    "enum": ["0", "1", "2-3", "4-5", "6-7", "8+"]
                }
            }
        },
        "aichat-onboarding": {
            "cohorts": ["control", "treatmentA", "treatmentB"],
            "metrics": {
                "aichat_type": {
                    "description": "Fires when the user taps on of the ai chat suggestions or types in the AI chat prompt",
                    "enum": ["custom", "option1", "option2", "option3"]
                },
                "search_type": {
                    "description": "Fires when the user taps on of the search suggestions or types in the search prompt",
                    "enum": ["custom", "option1", "option2", "option3"]
                },
                "screen-impression": {
                    "description": "Fires when an experiment screen is shown",
                    "enum": ["toggle-screen", "fire-dialog", "final-dialog"]
                },
                "cta-pressed": {
                    "description": "Fires when the user interacts with an experiment CTA",
                    "enum": ["toggle-continue-pressed_search", "toggle-continue-pressed_ai", "fire-button-pressed"]
                }
            }
        },
        "simplifiedSyncSetupExperiment": {
            "cohorts": ["control", "treatment"],
            "metrics": {
                "signup_direct": {
                    "description": "Fires when the user creates a new sync account directly (single-device setup).",
                    "enum": ["1"]
                },
                "signup_connect": {
                    "description": "Fires when the user creates a sync account by connecting to another device.",
                    "enum": ["1"]
                },
                "login": {
                    "description": "Fires when the user logs into an existing sync account via recovery code or pairing.",
                    "enum": ["1"]
                },
                "sync_disabled": {
                    "description": "Fires when the user disables sync.",
                    "enum": ["1"]
                },
                "sync_disabled_and_deleted": {
                    "description": "Fires when the user disables sync and deletes server data.",
                    "enum": ["1"]
                },
                "barcode_screen_shown": {
                    "description": "Fires when the QR/barcode screen is shown during setup.",
                    "enum": ["1"]
                },
                "barcode_scanner_success": {
                    "description": "Fires when the QR barcode is scanned successfully.",
                    "enum": ["1"]
                },
                "barcode_scanner_failed": {
                    "description": "Fires when the QR barcode fails to scan.",
                    "enum": ["1"]
                },
                "barcode_code_copied": {
                    "description": "Fires when the user copies the sync code from the barcode screen.",
                    "enum": ["1"]
                },
                "manual_code_entry_screen_shown": {
                    "description": "Fires when the manual code entry screen is shown.",
                    "enum": ["1"]
                },
                "manual_code_entered_success": {
                    "description": "Fires when the manually entered code is accepted.",
                    "enum": ["1"]
                },
                "manual_code_entered_failed": {
                    "description": "Fires when the manually entered code is rejected.",
                    "enum": ["1"]
                },
                "setup_ended_abandoned": {
                    "description": "Fires when the sync setup flow ends in abandonment.",
                    "enum": ["1"]
                },
                "setup_ended_successful": {
                    "description": "Fires when the sync setup flow ends successfully.",
                    "enum": ["1"]
                },
                "deep_link_flow_started": {
                    "description": "Fires when a sync deep link flow starts.",
                    "enum": ["1"]
                },
                "deep_link_flow_success": {
                    "description": "Fires when a sync deep link flow succeeds.",
                    "enum": ["1"]
                },
                "deep_link_flow_abandoned": {
                    "description": "Fires when a sync deep link flow is abandoned.",
                    "enum": ["1"]
                },
                "deep_link_timeout": {
                    "description": "Fires when a sync deep link flow times out.",
                    "enum": ["1"]
                }
            }
        }
    }
}
