{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "Sent at the end of a subscription purchase flow (App Store or Stripe), capturing the outcome, the step that failed when applicable, per-step latencies, and the funnel that initiated the purchase. Activations that don't resolve in-session can be completed on a later app launch.",
    "$comment": "{\"owners\":[\"samsymons\"]}",
    "type": "object",
    "required": ["meta", "global", "feature", "app"],
    "additionalProperties": false,
    "properties": {
        "meta": {
            "type": "object",
            "required": ["type", "version"],
            "additionalProperties": false,
            "properties": { "type": { "const": "ios-subscription-purchase" }, "version": { "const": "1.1.0" } }
        },
        "app": {
            "type": "object",
            "required": ["name", "version"],
            "additionalProperties": false,
            "properties": {
                "name": {
                    "type": "string",
                    "description": "The name of the application",
                    "enum": ["DuckDuckGo", "DuckDuckGo-Alpha", "DuckDuckGo-Experimental", "PacketTunnelProvider"]
                },
                "version": { "type": "string", "description": "The version of the application", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
                "form_factor": { "type": "string", "description": "The form factor of the device", "enum": ["phone", "tablet"] }
            }
        },
        "global": {
            "type": "object",
            "required": ["platform", "type", "sample_rate"],
            "additionalProperties": false,
            "properties": {
                "platform": { "type": "string", "description": "The platform the app is running on", "enum": ["iOS"] },
                "type": { "type": "string", "description": "The type of application", "enum": ["app"] },
                "sample_rate": { "type": "number", "description": "Sample rate for this event", "minimum": 0, "maximum": 1 },
                "is_first_daily_occurrence": {
                    "type": "boolean",
                    "description": "Whether this is the first occurrence of this event today. Only included when true."
                }
            }
        },
        "feature": {
            "type": "object",
            "required": ["name", "status", "data"],
            "additionalProperties": false,
            "properties": {
                "name": { "type": "string", "description": "The feature name for this event", "enum": ["subscription-purchase"] },
                "status": {
                    "type": "string",
                    "description": "The overall status of the operation",
                    "enum": ["SUCCESS", "FAILURE", "UNKNOWN"]
                },
                "data": {
                    "type": "object",
                    "required": ["ext"],
                    "additionalProperties": false,
                    "properties": {
                        "ext": {
                            "type": "object",
                            "additionalProperties": false,
                            "properties": {
                                "status_reason": {
                                    "type": "string",
                                    "description": "Reason attached to non-default outcomes. UNKNOWN uses partial_data when the flow was recovered without enough state to classify, or missing_entitlements when the activation timeout elapsed without entitlements being granted. SUCCESS uses missing_entitlements_delayed_activation when entitlements were granted on a later app launch rather than within the original session.",
                                    "enum": ["partial_data", "missing_entitlements", "missing_entitlements_delayed_activation"]
                                },
                                "purchase_platform": {
                                    "type": "string",
                                    "description": "Platform used to complete the purchase",
                                    "enum": ["app_store", "stripe"]
                                },
                                "failing_step": {
                                    "type": "string",
                                    "description": "The step the purchase flow failed on, when status is FAILURE",
                                    "enum": ["FLOW_START", "ACCOUNT_CREATE", "ACCOUNT_PAYMENT", "ACCOUNT_ACTIVATION"]
                                },
                                "subscription_identifier": {
                                    "type": "string",
                                    "description": "Subscription product identifier from the payment provider, e.g. ddg.privacy.pro.monthly.renews.us"
                                },
                                "free_trial_eligible": {
                                    "type": "boolean",
                                    "description": "Whether a free trial was available at the start of the flow"
                                },
                                "funnel_name": {
                                    "type": "string",
                                    "description": "Identifier for the funnel that led into the subscription flow",
                                    "pattern": "^funnel_"
                                },
                                "account_creation_latency_ms_bucketed": {
                                    "type": "integer",
                                    "description": "Bucketed latency for the account creation step (ms)",
                                    "enum": [1000, 5000, 10000, 30000, 60000, 300000, 600000]
                                },
                                "account_payment_latency_ms_bucketed": {
                                    "type": "integer",
                                    "description": "Bucketed latency for the purchase completion step (ms)",
                                    "enum": [1000, 5000, 10000, 30000, 60000, 300000, 600000]
                                },
                                "account_activation_latency_ms_bucketed": {
                                    "type": "integer",
                                    "description": "Bucketed latency for the account activation step (ms)",
                                    "enum": [1000, 5000, 10000, 30000, 60000, 300000, 600000]
                                },
                                "error": {
                                    "type": "object",
                                    "description": "Shared wide-event error details",
                                    "properties": {
                                        "domain": { "type": "string", "description": "The top level error domain" },
                                        "code": { "type": "integer", "description": "The top level error code" },
                                        "error_description": { "type": "string", "description": "Additional error description" },
                                        "underlying_domain": { "type": "string", "description": "The underlying error domain" },
                                        "underlying_code": { "type": "integer", "description": "The underlying error code" },
                                        "underlying_domain2": {
                                            "type": "string",
                                            "description": "The second nested underlying error domain"
                                        },
                                        "underlying_code2": { "type": "integer", "description": "The second nested underlying error code" },
                                        "underlying_domain3": {
                                            "type": "string",
                                            "description": "The third nested underlying error domain"
                                        },
                                        "underlying_code3": { "type": "integer", "description": "The third nested underlying error code" },
                                        "underlying_domain4": {
                                            "type": "string",
                                            "description": "The fourth nested underlying error domain"
                                        },
                                        "underlying_code4": { "type": "integer", "description": "The fourth nested underlying error code" },
                                        "underlying_domain5": {
                                            "type": "string",
                                            "description": "The fifth nested underlying error domain"
                                        },
                                        "underlying_code5": { "type": "integer", "description": "The fifth nested underlying error code" },
                                        "underlying_domain6": {
                                            "type": "string",
                                            "description": "The sixth nested underlying error domain"
                                        },
                                        "underlying_code6": { "type": "integer", "description": "The sixth nested underlying error code" },
                                        "underlying_domain7": {
                                            "type": "string",
                                            "description": "The seventh nested underlying error domain"
                                        },
                                        "underlying_code7": {
                                            "type": "integer",
                                            "description": "The seventh nested underlying error code"
                                        },
                                        "underlying_domain8": {
                                            "type": "string",
                                            "description": "The eighth nested underlying error domain"
                                        },
                                        "underlying_code8": { "type": "integer", "description": "The eighth nested underlying error code" },
                                        "underlying_domain9": {
                                            "type": "string",
                                            "description": "The ninth nested underlying error domain"
                                        },
                                        "underlying_code9": { "type": "integer", "description": "The ninth nested underlying error code" }
                                    },
                                    "additionalProperties": false
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
