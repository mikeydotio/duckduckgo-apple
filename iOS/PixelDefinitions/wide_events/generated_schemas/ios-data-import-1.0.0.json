{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "Wide pixel sent at the end of a data import flow",
    "$comment": "{\"owners\":[\"hanyutang-sandra\"]}",
    "type": "object",
    "required": ["meta", "global", "feature", "app", "context"],
    "additionalProperties": false,
    "properties": {
        "meta": {
            "type": "object",
            "required": ["type", "version"],
            "additionalProperties": false,
            "properties": { "type": { "const": "ios-data-import" }, "version": { "const": "1.0.0" } }
        },
        "app": {
            "type": "object",
            "required": ["name", "version"],
            "additionalProperties": false,
            "properties": {
                "name": {
                    "type": "string",
                    "description": "The name of the application",
                    "enum": ["DuckDuckGo", "DuckDuckGo-Alpha", "DuckDuckGo-Experimental"]
                },
                "version": { "type": "string", "description": "The version of the application", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
                "form_factor": { "type": "string", "description": "The form factor of the device", "enum": ["phone", "tablet"] }
            }
        },
        "global": {
            "type": "object",
            "required": ["platform", "type", "sample_rate"],
            "additionalProperties": false,
            "properties": {
                "platform": { "type": "string", "description": "The platform the app is running on", "enum": ["iOS"] },
                "type": { "type": "string", "description": "The type of application", "enum": ["app"] },
                "sample_rate": { "type": "number", "description": "Sample rate for this event", "minimum": 0, "maximum": 1 },
                "is_first_daily_occurrence": {
                    "type": "boolean",
                    "description": "Whether this is the first occurrence of this event today. Only included when true."
                }
            }
        },
        "feature": {
            "type": "object",
            "required": ["name", "status", "data"],
            "additionalProperties": false,
            "properties": {
                "name": { "type": "string", "description": "The feature name for this event", "enum": ["data-import"] },
                "status": {
                    "type": "string",
                    "description": "The overall status of the operation",
                    "enum": ["SUCCESS", "FAILURE", "CANCELLED", "UNKNOWN"]
                },
                "data": {
                    "type": "object",
                    "required": ["ext"],
                    "additionalProperties": false,
                    "properties": {
                        "ext": {
                            "type": "object",
                            "additionalProperties": false,
                            "properties": {
                                "status_reason": { "type": "string", "description": "Optional reason accompanying the feature status" },
                                "source": { "type": "string", "description": "Import source", "enum": ["chrome", "safari"] },
                                "bookmarks_status": {
                                    "type": "string",
                                    "description": "Final status of bookmarks import",
                                    "enum": ["SUCCESS", "FAILURE", "CANCELLED", "UNKNOWN"]
                                },
                                "passwords_status": {
                                    "type": "string",
                                    "description": "Final status of passwords import",
                                    "enum": ["SUCCESS", "FAILURE", "CANCELLED", "UNKNOWN"]
                                },
                                "creditCards_status": {
                                    "type": "string",
                                    "description": "Final status of creditCards import",
                                    "enum": ["SUCCESS", "FAILURE", "CANCELLED", "UNKNOWN"]
                                },
                                "bookmarks_status_reason": {
                                    "type": "string",
                                    "description": "Optional reason accompanying the bookmarks import status",
                                    "enum": ["partial_data", "timeout", "document_picker_cancelled"]
                                },
                                "passwords_status_reason": {
                                    "type": "string",
                                    "description": "Optional reason accompanying the passwords import status",
                                    "enum": ["partial_data", "timeout", "document_picker_cancelled"]
                                },
                                "creditCards_status_reason": {
                                    "type": "string",
                                    "description": "Optional reason accompanying the creditCards import status",
                                    "enum": ["partial_data", "timeout", "document_picker_cancelled"]
                                },
                                "latency_ms": { "type": "integer", "description": "Overall data import latency (in ms)" },
                                "bookmarks_importer_latency_ms": {
                                    "type": "integer",
                                    "description": "Latency for bookmarks importer (in ms)"
                                },
                                "passwords_importer_latency_ms": {
                                    "type": "integer",
                                    "description": "Latency for passwords importer (in ms)"
                                },
                                "creditCards_importer_latency_ms": {
                                    "type": "integer",
                                    "description": "Latency for creditCards importer (in ms)"
                                },
                                "bookmarks_error": {
                                    "type": "object",
                                    "description": "Error details for bookmarks import failure",
                                    "properties": {
                                        "domain": { "type": "string", "description": "Error domain for bookmarks import failure" },
                                        "code": { "type": "integer", "description": "Error code for bookmarks import failure" },
                                        "description": {
                                            "type": "string",
                                            "description": "Human-readable error description for bookmarks import failure",
                                            "examples": ["noData", "decryptionError", "dataCorrupted", "keychainError", "other"]
                                        },
                                        "underlying_domain": {
                                            "type": "string",
                                            "description": "Underlying error domain for bookmarks import failure"
                                        },
                                        "underlying_code": {
                                            "type": "integer",
                                            "description": "Underlying error code for bookmarks import failure"
                                        }
                                    }
                                },
                                "passwords_error": {
                                    "type": "object",
                                    "description": "Error details for passwords import failure",
                                    "properties": {
                                        "domain": { "type": "string", "description": "Error domain for passwords import failure" },
                                        "code": { "type": "integer", "description": "Error code for passwords import failure" },
                                        "description": {
                                            "type": "string",
                                            "description": "Human-readable error description for passwords import failure",
                                            "examples": ["noData", "decryptionError", "dataCorrupted", "keychainError", "other"]
                                        },
                                        "underlying_domain": {
                                            "type": "string",
                                            "description": "Underlying error domain for passwords import failure"
                                        },
                                        "underlying_code": {
                                            "type": "integer",
                                            "description": "Underlying error code for passwords import failure"
                                        }
                                    }
                                },
                                "creditCards_error": {
                                    "type": "object",
                                    "description": "Error details for creditCards import failure",
                                    "properties": {
                                        "domain": { "type": "string", "description": "Error domain for creditCards import failure" },
                                        "code": { "type": "integer", "description": "Error code for creditCards import failure" },
                                        "description": {
                                            "type": "string",
                                            "description": "Human-readable error description for creditCards import failure",
                                            "examples": ["noData", "decryptionError", "dataCorrupted", "keychainError", "other"]
                                        },
                                        "underlying_domain": {
                                            "type": "string",
                                            "description": "Underlying error domain for creditCards import failure"
                                        },
                                        "underlying_code": {
                                            "type": "integer",
                                            "description": "Underlying error code for creditCards import failure"
                                        }
                                    }
                                }
                            }
                        },
                        "error": {
                            "type": "object",
                            "required": ["domain", "code"],
                            "additionalProperties": false,
                            "properties": {
                                "domain": { "type": "string", "description": "Error domain for the failure" },
                                "code": { "type": "integer", "description": "Error code for the failure" },
                                "description": { "type": "string", "description": "Error description for the failure" },
                                "underlying_domain": { "type": "string", "description": "Underlying error domain" },
                                "underlying_code": { "type": "integer", "description": "Underlying error code" }
                            }
                        }
                    }
                }
            }
        },
        "context": {
            "type": "object",
            "required": ["name"],
            "additionalProperties": false,
            "properties": {
                "name": {
                    "type": "string",
                    "description": "Context name for the event",
                    "enum": [
                        "funnel_bookmarks_ios",
                        "funnel_passwords_ios",
                        "funnel_settings_ios",
                        "funnel_promo_ios",
                        "funnel_in_browser_promo_ios",
                        "funnel_whatsNew_ios"
                    ]
                }
            }
        }
    }
}
