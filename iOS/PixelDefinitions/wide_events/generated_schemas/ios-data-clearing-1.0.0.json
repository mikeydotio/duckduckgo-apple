                                            "enum": ["SUCCESS", "FAILURE"]
                                        },
                                        "clear_fireproofable_data_for_nonFireproof_domains_latency_ms": {
                                            "type": "integer",
                                            "description": "Latency for clear_fireproofable_data_for_nonFireproof_domains action (in ms)"
                                        },
                                        "clear_fireproofable_data_for_nonFireproof_domains_error": {
                                            "type": "object",
                                            "description": "Error details for clear_fireproofable_data_for_nonFireproof_domains action",
                                            "properties": {
                                                "domain": { "type": "string", "description": "Top level error domain" },
                                                "code": { "type": "integer", "description": "Top level error code" },
                                                "description": { "type": "string", "description": "Human-readable error description" },
                                                "underlying_domain": { "type": "string", "description": "Underlying error domain" },
                                                "underlying_code": { "type": "integer", "description": "Underlying error code" }
                                            }
