{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "Wide pixel sent at the end of a data clearing flow on iOS",
    "$comment": "{\"owners\":[\"hanyutang-sandra\"]}",
    "type": "object",
    "required": ["meta", "global", "feature", "app", "context"],
    "additionalProperties": false,
    "properties": {
        "meta": {
            "type": "object",
            "required": ["type", "version"],
            "additionalProperties": false,
            "properties": { "type": { "const": "ios-data-clearing" }, "version": { "const": "1.0.0" } }
        },
        "app": {
            "type": "object",
            "required": ["name", "version"],
            "additionalProperties": false,
            "properties": {
                "name": {
                    "type": "string",
                    "description": "The name of the application",
                    "enum": ["DuckDuckGo", "DuckDuckGo-Alpha", "DuckDuckGo-Experimental"]
                },
                "version": { "type": "string", "description": "The version of the application", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
                "form_factor": { "type": "string", "description": "The form factor of the device", "enum": ["phone", "tablet"] }
            }
        },
        "global": {
            "type": "object",
            "required": ["platform", "type", "sample_rate"],
            "additionalProperties": false,
            "properties": {
                "platform": { "type": "string", "description": "The platform the app is running on", "enum": ["iOS"] },
                "type": { "type": "string", "description": "The type of application", "enum": ["app"] },
                "sample_rate": { "type": "number", "description": "Sample rate for this event", "minimum": 0, "maximum": 1 },
                "is_first_daily_occurrence": {
                    "type": "boolean",
                    "description": "Whether this is the first occurrence of this event today. Only included when true."
                }
            }
        },
        "feature": {
            "type": "object",
            "required": ["name", "status", "data"],
            "additionalProperties": false,
            "properties": {
                "name": { "type": "string", "description": "The feature name for this event", "enum": ["data-clearing"] },
                "status": {
                    "type": "string",
                    "description": "The overall status of the operation",
                    "enum": ["SUCCESS", "FAILURE", "CANCELLED", "UNKNOWN"]
                },
                "data": {
                    "type": "object",
                    "required": ["ext"],
                    "additionalProperties": false,
                    "properties": {
                        "ext": {
                            "type": "object",
                            "additionalProperties": false,
                            "properties": {
                                "status_reason": {
                                    "type": "string",
                                    "description": "Reason for the current status",
                                    "enum": ["partial_data", "timeout"]
                                },
                                "included_options": {
                                    "type": "string",
                                    "description": "Comma-separated list of specific options selected (tabs, data, aiChats) (iOS only)",
                                    "enum": ["tabs", "data", "aiChats", "tabs,data", "tabs,aiChats", "data,aiChats", "tabs,data,aiChats"]
                                },
                                "trigger": {
                                    "type": "string",
                                    "description": "What initiated the clearing flow",
                                    "enum": ["manualFire", "autoClearOnLaunch", "autoClearOnForeground", "fireModeAutoClear"]
                                },
                                "scope": {
                                    "type": "string",
                                    "description": "Scope of the clearing action",
                                    "enum": ["tab", "fireMode", "normalMode", "all"]
                                },
                                "source": {
                                    "type": "string",
                                    "description": "Entry point that triggered the data clearing flow",
                                    "enum": ["browsing", "tabSwitcher", "settings", "quickFire", "deeplink", "autoClear"]
                                },
                                "overall_latency_ms": {
                                    "type": "integer",
                                    "description": "Duration from start of clearing attempt to end state (in ms). Rounded to 10ms precision, capped at 10000ms (10 seconds)."
                                },
                                "clear_tabs_status": {
                                    "type": "string",
                                    "description": "Final status of clear_tabs action",
                                    "enum": ["SUCCESS", "FAILURE"]
                                },
                                "clear_tabs_latency_ms": { "type": "integer", "description": "Latency for clear_tabs action (in ms)" },
                                "clear_tabs_error": {
                                    "type": "object",
                                    "description": "Error details for clear_tabs action",
                                    "properties": {
                                        "domain": { "type": "string", "description": "Top level error domain" },
                                        "code": { "type": "integer", "description": "Top level error code" },
                                        "description": { "type": "string", "description": "Human-readable error description" },
                                        "underlying_domain": { "type": "string", "description": "Underlying error domain" },
                                        "underlying_code": { "type": "integer", "description": "Underlying error code" }
                                    }
                                },
                                "clear_website_data": {
                                    "type": "object",
                                    "description": "Website data clearing sub-actions",
                                    "properties": {
                                        "clear_safely_removable_website_data_status": {
                                            "type": "string",
                                            "description": "Final status of clear_safely_removable_website_data action",
                                            "enum": ["SUCCESS", "FAILURE"]
                                        },
                                        "clear_safely_removable_website_data_latency_ms": {
                                            "type": "integer",
                                            "description": "Latency for clear_safely_removable_website_data action (in ms)"
