{
    "ios-data-clearing": {
        "description": "Sent at the end of a data clearing (Fire) flow, capturing the overall outcome plus per-action timing, status, and errors for each data category cleared. The journey resolves to SUCCESS when clearing completes, or UNKNOWN when it is orphaned and resolved on a later launch.",
        "owners": ["hanyutang-sandra"],
        "meta": {
            "type": "ios-data-clearing",
            "version": "1.0"
        },
        "feature": {
            "name": "data-clearing",
            "status": ["SUCCESS", "UNKNOWN"],
            "data": {
                "ext": {
                    "status_reason": {
                        "type": "string",
                        "description": "Reason accompanying an UNKNOWN status: partial_data = an orphaned flow was completed on a later launch; timeout = the clearing did not complete within the timeout window.",
                        "enum": ["partial_data", "timeout"]
                    },
                    "included_options": {
                        "type": "string",
                        "description": "Comma-separated list of specific options the user selected (tabs, data, aiChats).",
                        "examples": ["tabs", "data", "aiChats", "tabs,data", "tabs,data,aiChats"]
                    },
                    "trigger": {
                        "type": "string",
                        "description": "What initiated the clearing flow.",
                        "enum": ["manualFire", "autoClearOnLaunch", "autoClearOnForeground", "fireModeAutoClear"]
                    },
                    "scope": {
                        "type": "string",
                        "description": "Scope of the clearing action.",
                        "enum": ["tab", "all", "fireMode", "normalMode"]
                    },
                    "source": {
                        "type": "string",
                        "description": "Entry point that triggered the data clearing flow.",
                        "enum": [
                            "browsing",
                            "escapeHatch",
                            "tabSwitcher",
                            "settings",
                            "quickFire",
                            "deeplink",
                            "autoClear",
                            "chatSuggestions"
                        ]
                    },
                    "overall_latency_ms": {
                        "type": "integer",
                        "description": "Duration from start of the clearing attempt to its end state (in ms). Rounded to 10ms precision, capped at 10000ms (10 seconds)."
                    },
                    "clear_tabs_status": {
                        "type": "string",
                        "description": "Final status of the clear_tabs action.",
                        "enum": ["SUCCESS", "FAILURE"]
                    },
                    "clear_tabs_latency_ms": {
                        "type": "integer",
                        "description": "Duration from start of the action to its end state (in ms). Rounded to 10ms precision, capped at 10000ms (10 seconds)."
                    },
                    "clear_tabs_error": "dataClearingActionError",
                    "clear_all_history_status": {
                        "type": "string",
                        "description": "Final status of the clear_all_history action.",
                        "enum": ["SUCCESS", "FAILURE"]
                    },
                    "clear_all_history_latency_ms": {
                        "type": "integer",
                        "description": "Duration from start of the action to its end state (in ms). Rounded to 10ms precision, capped at 10000ms (10 seconds)."
                    },
                    "clear_all_history_error": "dataClearingActionError",
                    "clear_aiChat_history_status": {
                        "type": "string",
                        "description": "Final status of the clear_aiChat_history action.",
                        "enum": ["SUCCESS", "FAILURE"]
                    },
                    "clear_aiChat_history_latency_ms": {
                        "type": "integer",
                        "description": "Duration from start of the action to its end state (in ms). Rounded to 10ms precision, capped at 10000ms (10 seconds)."
                    },
                    "clear_aiChat_history_error": "dataClearingActionError",
                    "clear_autoconsent_management_cache_status": {
                        "type": "string",
                        "description": "Final status of the clear_autoconsent_management_cache action.",
                        "enum": ["SUCCESS", "FAILURE"]
                    },
                    "clear_autoconsent_management_cache_latency_ms": {
                        "type": "integer",
                        "description": "Duration from start of the action to its end state (in ms). Rounded to 10ms precision, capped at 10000ms (10 seconds)."
                    },
                    "clear_autoconsent_management_cache_error": "dataClearingActionError",
                    "clear_favicon_cache_status": {
                        "type": "string",
