                    },
                    "clear_privacy_stats_latency_ms": {
                        "type": "integer",
                        "description": "Duration from start of the action to its end state (in ms). Rounded to 10ms precision, capped at 10000ms (10 seconds)."
                    },
                    "clear_privacy_stats_error": "dataClearingActionError",
                    "clear_url_caches_status": {
                        "type": "string",
                        "description": "Final status of the clear_url_caches action.",
                        "enum": ["SUCCESS", "FAILURE"]
                    },
                    "clear_url_caches_latency_ms": {
                        "type": "integer",
                        "description": "Duration from start of the action to its end state (in ms). Rounded to 10ms precision, capped at 10000ms (10 seconds)."
                    },
                    "clear_url_caches_error": "dataClearingActionError",
                    "clear_daxDialogs_held_URL_data_status": {
                        "type": "string",
                        "description": "Final status of the clear_daxDialogs_held_URL_data action.",
                        "enum": ["SUCCESS", "FAILURE"]
                    },
                    "clear_daxDialogs_held_URL_data_latency_ms": {
                        "type": "integer",
