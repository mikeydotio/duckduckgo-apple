                    },
                    "clear_daxDialogs_held_URL_data_error": "dataClearingActionError",
                    "delete_contextual_aiChat_status": {
                        "type": "string",
                        "description": "Final status of the delete_contextual_aiChat action.",
                        "enum": ["SUCCESS", "FAILURE"]
                    },
                    "delete_contextual_aiChat_latency_ms": {
