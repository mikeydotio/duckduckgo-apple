                                "description": "Final status of remove_all_containers_after_delay action",
                                "enum": ["SUCCESS", "FAILURE"]
                            },
                            "remove_all_containers_after_delay_latency_ms": {
                                "type": "integer",
                                "description": "Latency for remove_all_containers_after_delay action (in ms)"
                            },
                            "remove_all_containers_after_delay_error": {
                                "type": "object",
