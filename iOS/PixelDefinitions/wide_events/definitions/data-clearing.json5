                    },
                    "clear_favicon_cache_error": "dataClearingActionError",
                    "cancel_all_downloads_status": {
                        "type": "string",
                        "description": "Final status of the cancel_all_downloads action.",
                        "enum": ["SUCCESS", "FAILURE"]
                    },
                    "cancel_all_downloads_latency_ms": {
                        "type": "integer",
                        "description": "Duration from start of the action to its end state (in ms). Rounded to 10ms precision, capped at 10000ms (10 seconds)."
                    },
                    "cancel_all_downloads_error": "dataClearingActionError",
                    "clear_bookmark_database_status": {
                        "type": "string",
                        "description": "Final status of the clear_bookmark_database action.",
                        "enum": ["SUCCESS", "FAILURE"]
                    },
                    "clear_bookmark_database_latency_ms": {
                        "type": "integer",
                        "description": "Duration from start of the action to its end state (in ms). Rounded to 10ms precision, capped at 10000ms (10 seconds)."
                    },
                    "clear_bookmark_database_error": "dataClearingActionError",
                    "forget_text_zoom_status": {
