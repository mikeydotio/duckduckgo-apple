                                "description": "Latency for clear_cookies_for_nonFireproofed_domains action (in ms)"
                            },
                            "clear_cookies_for_nonFireproofed_domains_error": {
                                "type": "object",
                                "description": "Error details for clear_cookies_for_nonFireproofed_domains action",
                                "properties": {
                                    "domain": { "type": "string", "description": "Top level error domain" },
                                    "code": { "type": "integer", "description": "Top level error code" },
                                    "description": { "type": "string", "description": "Human-readable error description" },
                                    "underlying_domain": { "type": "string", "description": "Underlying error domain" },
                                    "underlying_code": { "type": "integer", "description": "Underlying error code" }
                                }
                            },
                            "remove_observations_data_status": {
                                "type": "string",
                                "description": "Final status of remove_observations_data action",
                                "enum": ["SUCCESS", "FAILURE"]
                            },
                            "remove_observations_data_latency_ms": {
                                "type": "integer",
                                "description": "Latency for remove_observations_data action (in ms)"
                            },
                            "remove_observations_data_error": {
                                "type": "object",
