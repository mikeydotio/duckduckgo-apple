                        "enum": ["SUCCESS", "FAILURE"]
                    },
                    "clear_autoconsent_management_cache_fire_mode_latency_ms": {
                        "type": "integer",
                        "description": "Duration from start of the action to its end state (in ms). Rounded to 10ms precision, capped at 10000ms (10 seconds)."
                    },
                    "clear_autoconsent_management_cache_fire_mode_error": "dataClearingActionError",
                    "forget_text_zoom_fire_mode_status": {
                        "type": "string",
                        "description": "Final status of the forget_text_zoom_fire_mode action.",
                        "enum": ["SUCCESS", "FAILURE"]
                    },
