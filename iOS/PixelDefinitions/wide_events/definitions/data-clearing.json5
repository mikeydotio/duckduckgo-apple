                    },
                    "forget_text_zoom_fire_mode_error": "dataClearingActionError",
                    "clear_website_data": {
                        "type": "object",
                        "description": "Per-sub-action results for website-data clearing (status, latency, and error for each website-data step).",
                        "properties": {
                            "clear_safely_removable_website_data_status": {
                                "type": "string",
                                "description": "Final status of the clear_website_data.clear_safely_removable_website_data action.",
                                "enum": ["SUCCESS", "FAILURE"]
                            },
                            "clear_safely_removable_website_data_latency_ms": {
                                "type": "integer",
                                "description": "Duration from start of the action to its end state (in ms). Rounded to 10ms precision, capped at 10000ms (10 seconds)."
                            },
                            "clear_safely_removable_website_data_error": "dataClearingActionError",
                            "clear_fireproofable_data_for_nonFireproof_domains_status": {
                                "type": "string",
                                "description": "Final status of the clear_website_data.clear_fireproofable_data_for_nonFireproof_domains action.",
                                "enum": ["SUCCESS", "FAILURE"]
                            },
                            "clear_fireproofable_data_for_nonFireproof_domains_latency_ms": {
