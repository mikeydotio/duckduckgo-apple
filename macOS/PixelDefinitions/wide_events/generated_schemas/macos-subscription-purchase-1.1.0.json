{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "Sent at the end of a Privacy Pro subscription purchase journey, from the moment the user initiates a purchase on the paywall through account creation, payment, and entitlement activation, until the purchase succeeds, fails, is cancelled by the user, or is orphaned by app termination and resolved on a later launch.",
    "$comment": "{\"owners\":[\"samsymons\"]}",
    "type": "object",
    "required": ["meta", "global", "feature", "app"],
    "additionalProperties": false,
    "properties": {
        "meta": {
            "type": "object",
            "required": ["type", "version"],
            "additionalProperties": false,
            "properties": { "type": { "const": "macos-subscription-purchase" }, "version": { "const": "1.1.0" } }
        },
        "app": {
            "type": "object",
            "required": ["name", "version"],
            "additionalProperties": false,
            "properties": {
                "name": {
                    "type": "string",
                    "description": "The name of the app sending the event, taken from CFBundleName. Varies across build configurations and the target (main app, VPN agent, PIR agent, network extension). Extend this enum when adding wide events fired from other macOS targets.",
                    "enum": [
                        "DuckDuckGo",
                        "DuckDuckGo Alpha",
                        "DuckDuckGo Review",
                        "DuckDuckGo App Store",
                        "DuckDuckGo VPN",
                        "DuckDuckGo VPN Alpha",
                        "DuckDuckGo VPN Review",
                        "DuckDuckGo VPN App Store",
                        "DuckDuckGo Personal Information Removal",
                        "DuckDuckGo Personal Information Removal App Store",
                        "NetworkProtectionAppExtension",
                        "com.duckduckgo.macos.vpn.network-extension",
                        "com.duckduckgo.macos.vpn.network-extension.debug",
                        "com.duckduckgo.macos.vpn.network-extension.review",
                        "com.duckduckgo.macos.vpn.network-extension.alpha",
                        "com.duckduckgo.mobile.ios.vpn.agent.network-extension"
                    ]
                },
                "version": { "type": "string", "description": "The version of the application", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" }
            }
        },
        "global": {
            "type": "object",
            "required": ["platform", "type", "sample_rate"],
            "additionalProperties": false,
            "properties": {
                "platform": { "type": "string", "description": "The platform the app is running on", "enum": ["macOS"] },
                "type": { "type": "string", "description": "The type of application", "enum": ["app"] },
                "sample_rate": { "type": "number", "description": "Sample rate for this event", "minimum": 0, "maximum": 1 },
                "is_first_daily_occurrence": {
                    "type": "boolean",
                    "description": "Whether this is the first occurrence of this event today. Only included when true."
                }
            }
        },
        "feature": {
            "type": "object",
            "required": ["name", "status", "data"],
            "additionalProperties": false,
            "properties": {
                "name": { "type": "string", "description": "The feature name for this event", "enum": ["subscription-purchase"] },
                "status": {
                    "type": "string",
                    "description": "The overall status of the operation",
                    "enum": ["SUCCESS", "FAILURE", "CANCELLED", "UNKNOWN"]
                },
                "data": {
                    "type": "object",
                    "required": ["ext"],
                    "additionalProperties": false,
                    "properties": {
                        "ext": {
                            "type": "object",
                            "additionalProperties": false,
                            "properties": {
                                "status_reason": {
                                    "type": "string",
                                    "description": "Reason accompanying outcomes that are not a clean terminal result at send time. `partial_data` = an orphaned flow was completed after app launch without enough captured data to classify it; `missing_entitlements` = entitlements were still not present when the activation timeout elapsed (sent as UNKNOWN); `missing_entitlements_delayed_activation` = entitlements were initially missing but appeared on a later app launch, so the purchase is counted as a delayed SUCCESS.",
                                    "enum": ["partial_data", "missing_entitlements", "missing_entitlements_delayed_activation"]
                                },
                                "purchase_platform": {
                                    "type": "string",
                                    "description": "The platform used to make the purchase.",
                                    "enum": ["app_store", "stripe"]
                                },
                                "failing_step": {
                                    "type": "string",
                                    "description": "The step the purchase journey failed on. Present on FAILURE outcomes.",
                                    "enum": ["FLOW_START", "ACCOUNT_CREATE", "ACCOUNT_PAYMENT", "ACCOUNT_ACTIVATION"]
                                },
                                "subscription_identifier": {
                                    "type": "string",
                                    "description": "Identifier of the subscription product the user attempted to purchase, for example ddg.privacy.pro.monthly.renews.us."
                                },
                                "free_trial_eligible": {
                                    "type": "boolean",
                                    "description": "Whether the user was eligible for a free trial at the time of purchase."
                                },
                                "funnel_name": {
                                    "type": "string",
                                    "description": "Name of the funnel or entry point that originated the purchase, for example funnel_onboarding_ios."
                                },
                                "account_creation_latency_ms_bucketed": {
                                    "type": "integer",
                                    "description": "Time taken to create the account, in milliseconds, rounded up into a bucket.",
                                    "enum": [1000, 5000, 10000, 30000, 60000, 300000, 600000]
                                },
                                "account_payment_latency_ms_bucketed": {
                                    "type": "integer",
                                    "description": "Time taken to complete the payment, in milliseconds, rounded up into a bucket.",
                                    "enum": [1000, 5000, 10000, 30000, 60000, 300000, 600000]
                                },
                                "account_activation_latency_ms_bucketed": {
                                    "type": "integer",
                                    "description": "Time taken to activate the account once entitlements became available, in milliseconds, rounded up into a bucket.",
                                    "enum": [1000, 5000, 10000, 30000, 60000, 300000, 600000]
                                },
                                "error": {
                                    "type": "object",
                                    "description": "Shared wide-event error details",
                                    "properties": {
                                        "domain": { "type": "string", "description": "The top level error domain" },
                                        "code": { "type": "integer", "description": "The top level error code" },
                                        "error_description": { "type": "string", "description": "Additional error description" },
                                        "underlying_domain": { "type": "string", "description": "The underlying error domain" },
                                        "underlying_code": { "type": "integer", "description": "The underlying error code" },
                                        "underlying_domain2": {
                                            "type": "string",
                                            "description": "The second nested underlying error domain"
                                        },
                                        "underlying_code2": { "type": "integer", "description": "The second nested underlying error code" },
                                        "underlying_domain3": {
                                            "type": "string",
                                            "description": "The third nested underlying error domain"
                                        },
                                        "underlying_code3": { "type": "integer", "description": "The third nested underlying error code" },
                                        "underlying_domain4": {
                                            "type": "string",
                                            "description": "The fourth nested underlying error domain"
                                        },
                                        "underlying_code4": { "type": "integer", "description": "The fourth nested underlying error code" },
                                        "underlying_domain5": {
                                            "type": "string",
                                            "description": "The fifth nested underlying error domain"
                                        },
                                        "underlying_code5": { "type": "integer", "description": "The fifth nested underlying error code" },
                                        "underlying_domain6": {
                                            "type": "string",
                                            "description": "The sixth nested underlying error domain"
                                        },
                                        "underlying_code6": { "type": "integer", "description": "The sixth nested underlying error code" },
                                        "underlying_domain7": {
                                            "type": "string",
                                            "description": "The seventh nested underlying error domain"
                                        },
                                        "underlying_code7": {
                                            "type": "integer",
                                            "description": "The seventh nested underlying error code"
                                        },
                                        "underlying_domain8": {
                                            "type": "string",
                                            "description": "The eighth nested underlying error domain"
                                        },
                                        "underlying_code8": { "type": "integer", "description": "The eighth nested underlying error code" },
                                        "underlying_domain9": {
                                            "type": "string",
                                            "description": "The ninth nested underlying error domain"
                                        },
                                        "underlying_code9": { "type": "integer", "description": "The ninth nested underlying error code" }
                                    },
                                    "additionalProperties": false
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
