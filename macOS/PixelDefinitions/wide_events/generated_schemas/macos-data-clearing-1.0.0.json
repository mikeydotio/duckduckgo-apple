{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "Wide pixel sent at the end of a data clearing flow",
    "$comment": "{\"owners\":[\"hanyutang-sandra\"]}",
    "type": "object",
    "required": ["meta", "global", "feature", "app", "context"],
    "additionalProperties": false,
    "properties": {
        "meta": {
            "type": "object",
            "required": ["type", "version"],
            "additionalProperties": false,
            "properties": { "type": { "const": "macos-data-clearing" }, "version": { "const": "1.0.0" } }
        },
        "app": {
            "type": "object",
            "required": ["name", "version"],
            "additionalProperties": false,
            "properties": {
                "name": {
                    "type": "string",
                    "description": "The name of the app sending the event, taken from CFBundleName. Varies across build configurations and the target (main app, VPN agent, network extension). Extend this enum when adding wide events fired from other macOS targets.",
                    "enum": [
                        "DuckDuckGo",
                        "DuckDuckGo Alpha",
                        "DuckDuckGo Review",
                        "DuckDuckGo App Store",
                        "DuckDuckGo VPN",
                        "DuckDuckGo VPN Alpha",
                        "DuckDuckGo VPN Review",
                        "DuckDuckGo VPN App Store",
                        "com.duckduckgo.macos.vpn.network-extension",
                        "com.duckduckgo.macos.vpn.network-extension.debug",
                        "com.duckduckgo.macos.vpn.network-extension.review",
                        "com.duckduckgo.macos.vpn.network-extension.alpha",
                        "com.duckduckgo.mobile.ios.vpn.agent.network-extension"
                    ]
                },
                "version": { "type": "string", "description": "The version of the application", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" }
            }
        },
        "global": {
            "type": "object",
            "required": ["platform", "type", "sample_rate"],
            "additionalProperties": false,
            "properties": {
                "platform": { "type": "string", "description": "The platform the app is running on", "enum": ["macOS"] },
                "type": { "type": "string", "description": "The type of application", "enum": ["app"] },
                "sample_rate": { "type": "number", "description": "Sample rate for this event", "minimum": 0, "maximum": 1 },
                "is_first_daily_occurrence": {
                    "type": "boolean",
                    "description": "Whether this is the first occurrence of this event today. Only included when true."
                }
            }
        },
        "feature": {
            "type": "object",
            "required": ["name", "status", "data"],
            "additionalProperties": false,
            "properties": {
                "name": { "type": "string", "description": "The feature name for this event", "enum": ["data-clearing"] },
                "status": {
                    "type": "string",
                    "description": "The overall status of the operation",
                    "enum": ["SUCCESS", "FAILURE", "CANCELLED", "UNKNOWN"]
                },
                "data": {
                    "type": "object",
                    "required": ["ext"],
                    "additionalProperties": false,
                    "properties": {
                        "ext": {
                            "type": "object",
                            "additionalProperties": false,
                            "properties": {
                                "status_reason": {
                                    "type": "string",
                                    "description": "Reason for the current status",
                                    "enum": ["partial_data", "timeout"]
                                },
                                "options": {
                                    "type": "string",
                                    "description": "What data the user selected for clearing",
                                    "enum": ["currentTab", "currentWindow", "allData"]
                                },
                                "trigger": {
                                    "type": "string",
                                    "description": "What initiated the clearing flow",
                                    "enum": ["manual", "autoClear"]
                                },
                                "path": {
                                    "type": "string",
                                    "description": "Execution path during clearing",
                                    "enum": ["burnEntity", "burnAll", "burnVisits"]
                                },
                                "included_domains": {
                                    "type": "string",
                                    "description": "Comma-separated list of domain categories included",
                                    "enum": [
                                        "History",
                                        "TabsAndWindows",
                                        "History,TabsAndWindows",
                                        "CookiesAndSiteData",
                                        "History,CookiesAndSiteData",
                                        "TabsAndWindows,CookiesAndSiteData",
                                        "History,TabsAndWindows,CookiesAndSiteData",
                                        "ChatHistory",
                                        "History,ChatHistory",
                                        "TabsAndWindows,ChatHistory",
                                        "History,TabsAndWindows,ChatHistory",
                                        "CookiesAndSiteData,ChatHistory",
                                        "History,CookiesAndSiteData,ChatHistory",
                                        "TabsAndWindows,CookiesAndSiteData,ChatHistory",
                                        "History,TabsAndWindows,CookiesAndSiteData,ChatHistory"
                                    ]
                                },
                                "overall_latency_ms": {
                                    "type": "integer",
                                    "description": "Duration from start of clearing attempt to end state (in ms). Rounded to 10ms precision, capped at 10000ms (10 seconds)."
                                },
                                "clear_tabs_status": {
                                    "type": "string",
                                    "description": "Final status of clear_tabs action",
                                    "enum": ["SUCCESS", "FAILURE"]
                                },
                                "clear_tabs_latency_ms": { "type": "integer", "description": "Latency for clear_tabs action (in ms)" },
                                "clear_tabs_error": {
                                    "type": "object",
                                    "description": "Error details for clear_tabs action",
                                    "properties": {
                                        "domain": { "type": "string", "description": "Top level error domain" },
                                        "code": { "type": "integer", "description": "Top level error code" },
                                        "description": { "type": "string", "description": "Human-readable error description" },
                                        "underlying_domain": { "type": "string", "description": "Underlying error domain" },
                                        "underlying_code": { "type": "integer", "description": "Underlying error code" }
                                    }
                                },
                                "clear_website_data": {
                                    "type": "object",
                                    "description": "Website data clearing sub-actions",
                                    "properties": {
                                        "clear_safely_removable_website_data_status": {
                                            "type": "string",
                                            "description": "Final status of clear_safely_removable_website_data action",
                                            "enum": ["SUCCESS", "FAILURE"]
                                        },
                                        "clear_safely_removable_website_data_latency_ms": {
                                            "type": "integer",
