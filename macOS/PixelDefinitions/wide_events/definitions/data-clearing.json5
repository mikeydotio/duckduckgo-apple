{
    "macos-data-clearing": {
        "description": "Wide pixel sent at the end of a data clearing flow",
        "owners": ["hanyutang-sandra"],
        "meta": {
            "type": "macos-data-clearing",
            "version": "0.0"
        },
        "feature": {
            "name": "data-clearing",
            "status": ["SUCCESS", "FAILURE", "CANCELLED", "UNKNOWN"],
            "data": {
                "ext": {
                    "status_reason": {
                        "type": "string",
                        "description": "Reason for the current status",
                        "enum": ["partial_data", "timeout"]
                    },
                    "options": {
                        "type": "string",
                        "description": "What data the user selected for clearing",
                        "enum": ["currentTab", "currentWindow", "allData"]
                    },
                    "trigger": {
                        "type": "string",
                        "description": "What initiated the clearing flow",
                        "enum": ["manual", "autoClear"]
                    },
                    "path": {
                        "type": "string",
                        "description": "Execution path during clearing",
                        "enum": ["burnEntity", "burnAll", "burnVisits"]
                    },
                    "included_domains": {
                        "type": "string",
                        "description": "Comma-separated list of domain categories included",
                        "enum": [
                            "History",
                            "TabsAndWindows",
                            "History,TabsAndWindows",
                            "CookiesAndSiteData",
                            "History,CookiesAndSiteData",
                            "TabsAndWindows,CookiesAndSiteData",
                            "History,TabsAndWindows,CookiesAndSiteData",
                            "ChatHistory",
                            "History,ChatHistory",
                            "TabsAndWindows,ChatHistory",
                            "History,TabsAndWindows,ChatHistory",
                            "CookiesAndSiteData,ChatHistory",
                            "History,CookiesAndSiteData,ChatHistory",
                            "TabsAndWindows,CookiesAndSiteData,ChatHistory",
                            "History,TabsAndWindows,CookiesAndSiteData,ChatHistory"
                        ]
                    },
                    "overall_latency_ms": {
                        "type": "integer",
                        "description": "Duration from start of clearing attempt to end state (in ms). Rounded to 10ms precision, capped at 10000ms (10 seconds)."
                    },
                    "clear_tabs_status": {
                        "type": "string",
                        "description": "Final status of clear_tabs action",
                        "enum": ["SUCCESS", "FAILURE"]
                    },
                    "clear_tabs_latency_ms": { "type": "integer", "description": "Latency for clear_tabs action (in ms)" },
                    "clear_tabs_error": {
                        "type": "object",
                        "description": "Error details for clear_tabs action",
                        "properties": {
                            "domain": { "type": "string", "description": "Top level error domain" },
                            "code": { "type": "integer", "description": "Top level error code" },
                            "description": { "type": "string", "description": "Human-readable error description" },
                            "underlying_domain": { "type": "string", "description": "Underlying error domain" },
                            "underlying_code": { "type": "integer", "description": "Underlying error code" }
                        }
                    },
                    "clear_website_data": {
                        "type": "object",
                        "description": "Website data clearing sub-actions",
                        "properties": {
                            "clear_safely_removable_website_data_status": {
                                "type": "string",
                                "description": "Final status of clear_safely_removable_website_data action",
                                "enum": ["SUCCESS", "FAILURE"]
                            },
                            "clear_safely_removable_website_data_latency_ms": {
                                "type": "integer",
                                "description": "Latency for clear_safely_removable_website_data action (in ms)"
