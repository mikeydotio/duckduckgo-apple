{
    "macos-free-trial-conversion": {
        "description": "Wide pixel sent at the end of a free trial conversion flow, tracking whether the user activated VPN/PIR and converted to a paid subscription",
        "owners": ["jozsef-vesza"],
        "meta": {
            "type": "macos-free-trial-conversion",
            "version": "0.0"
        },
        "feature": {
            "name": "free-trial-conversion",
            "status": ["SUCCESS", "FAILURE", "CANCELLED", "UNKNOWN"],
            "data": {
                "ext": {
                    "status_reason": {
                        "type": "string",
                        "description": "Optional reason accompanying the feature status"
                    },
                    "step": {
                        "type": "object",
                        "description": "Free trial activation steps",
                        "properties": {
                            "vpn_activated_d1": {
                                "type": "boolean",
                                "description": "Whether VPN was activated on Day 1 of the free trial"
                            },
                            "vpn_activated_d2_to_d7": {
                                "type": "boolean",
                                "description": "Whether VPN was activated between Day 2 and Day 7 of the free trial"
                            },
                            "pir_activated_d1": {
                                "type": "boolean",
                                "description": "Whether PIR was activated on Day 1 of the free trial"
                            },
                            "pir_activated_d2_to_d7": {
                                "type": "boolean",
                                "description": "Whether PIR was activated between Day 2 and Day 7 of the free trial"
                            },
                            "duck_ai_activated_d1": {
                                "type": "boolean",
                                "description": "Whether Duck.ai was activated on Day 1 of the free trial"
                            },
                            "duck_ai_activated_d2_to_d7": {
                                "type": "boolean",
                                "description": "Whether Duck.ai was activated between Day 2 and Day 7 of the free trial"
                            }
                        }
                    }
                }
            }
        }
    }
}
