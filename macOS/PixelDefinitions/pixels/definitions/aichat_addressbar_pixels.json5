        "owners": ["Bunn"],
        "triggers": ["other"],
        "suffixes": ["first_daily_count"],
        "parameters": ["appVersion", "pixelSource", "channel"]
    },
    "m_mac_aichat_addressbar_image_attached": {
        "description": "Fired when user attaches an image via the file picker in the duck.ai omnibar",
        "owners": ["tomasstrba"],
        "triggers": ["other"],
        "suffixes": ["daily_count"],
        "parameters": ["appVersion", "pixelSource", "channel"]
    },
    "m_mac_aichat_addressbar_image_removed": {
        "description": "Fired when user removes an attached image in the duck.ai omnibar",
        "owners": ["tomasstrba"],
        "triggers": ["other"],
        "suffixes": ["daily_count"],
        "parameters": ["appVersion", "pixelSource", "channel"]
    },
    "m_mac_aichat_addressbar_submit_with_image": {
        "description": "Fired when user submits a prompt that includes one or more image attachments",
        "owners": ["tomasstrba"],
        "triggers": ["other"],
        "suffixes": ["daily_count"],
        "parameters": [
            "appVersion",
            "pixelSource",
            "channel",
            {
                "key": "imageCount",
                "type": "integer",
                "description": "Number of images attached to the submitted prompt"
            }
        ]
    },
    "m_mac_aichat_addressbar_submit_with_tabs": {
        "description": "Fired when user submits a prompt that includes one or more page-content tab attachments via the omnibar's Attach Page Content menu",
        "owners": ["tomasstrba"],
        "triggers": ["other"],
        "suffixes": ["daily_count"],
        "parameters": [
            "appVersion",
            "pixelSource",
            "channel",
            {
                "key": "tabCount",
                "type": "integer",
                "description": "Number of tabs attached to the submitted prompt"
            }
        ]
    },
    "m_mac_aichat_addressbar_file_attached": {
        "description": "Fired when user attaches a file (PDF etc.) via the file picker in the duck.ai omnibar",
        "owners": ["tomasstrba"],
        "triggers": ["other"],
        "suffixes": ["daily_count"],
        "parameters": ["appVersion", "pixelSource", "channel"]
    },
    "m_mac_aichat_addressbar_file_removed": {
        "description": "Fired when user removes an attached file (PDF etc.) in the duck.ai omnibar by clicking the × on the carousel card",
        "owners": ["tomasstrba"],
        "triggers": ["other"],
        "suffixes": ["daily_count"],
        "parameters": ["appVersion", "pixelSource", "channel"]
    },
    "m_mac_aichat_addressbar_file_validation_failed": {
        "description": "Fired when a file picked for the duck.ai omnibar is rejected at pick-time by the attachment validator (too large, over the total-size budget, too many pages, unsupported type, encrypted, or unreadable)",
        "owners": ["tomasstrba"],
        "triggers": ["other"],
        "suffixes": ["daily_count"],
        "parameters": [
            "appVersion",
            "pixelSource",
            "channel",
            {
                "key": "reason",
                "description": "Reason for the file validation failure.",
                "type": "string",
                "enum": ["size_exceeded", "count_exceeded", "unsupported_type", "encrypted", "unreadable", "other"]
            }
        ]
    },
    "m_mac_aichat_addressbar_attach_tabs_picker_shown": {
        "description": "Fired when user opens the duck.ai omnibar attach menu's 'Add Page Content' submenu, which lists open tabs whose page content can be attached",
        "owners": ["tomasstrba"],
        "triggers": ["other"],
        "suffixes": ["daily_count"],
        "parameters": ["appVersion", "pixelSource", "channel"]
    },
    "m_mac_aichat_addressbar_attach_tab_chosen": {
        "description": "Fired when user toggles a tab ON in the duck.ai omnibar's 'Add Page Content' submenu — i.e. adds that tab's page content as an attachment",
        "owners": ["tomasstrba"],
        "triggers": ["other"],
        "suffixes": ["daily_count"],
        "parameters": ["appVersion", "pixelSource", "channel"]
    },
    "m_mac_aichat_addressbar_attach_tab_removed": {
        "description": "Fired when user toggles a tab OFF from inside the duck.ai omnibar's 'Add Page Content' submenu — i.e. removes that tab's page content attachment by clicking its row again",
        "owners": ["tomasstrba"],
        "triggers": ["other"],
        "suffixes": ["daily_count"],
        "parameters": ["appVersion", "pixelSource", "channel"]
    },
    "m_mac_aichat_addressbar_attach_picker_canceled": {
        "description": "Fired when user dismisses the duck.ai omnibar's 'Add Page Content' submenu without toggling any tab on or off during that open session",
        "owners": ["tomasstrba"],
        "triggers": ["other"],
        "suffixes": ["daily_count"],
        "parameters": ["appVersion", "pixelSource", "channel"]
    },
    "m_mac_aichat_addressbar_mention_picker_shown": {
        "description": "Fired when the duck.ai omnibar's @-mention tab picker appears — i.e. the user typed @ in the prompt and the picker became visible",
        "owners": ["tomasstrba"],
        "triggers": ["other"],
        "suffixes": ["daily_count"],
        "parameters": ["appVersion", "pixelSource", "channel"]
    },
    "m_mac_aichat_addressbar_mention_tab_chosen": {
        "description": "Fired when user picks a previously-unattached tab in the duck.ai omnibar's @-mention picker — i.e. adds that tab as an attachment via @",
        "owners": ["tomasstrba"],
        "triggers": ["other"],
        "suffixes": ["daily_count"],
        "parameters": ["appVersion", "pixelSource", "channel"]
    },
    "m_mac_aichat_addressbar_mention_tab_removed": {
        "description": "Fired when user picks an already-attached tab in the duck.ai omnibar's @-mention picker — i.e. removes that tab's page-content attachment via @",
        "owners": ["tomasstrba"],
        "triggers": ["other"],
        "suffixes": ["daily_count"],
        "parameters": ["appVersion", "pixelSource", "channel"]
    },
    "m_mac_aichat_addressbar_mention_picker_canceled": {
        "description": "Fired when user dismisses the duck.ai omnibar's @-mention picker without accepting any row (Esc, click outside, caret leaves the @-token, etc.). Pressing Enter while the picker shows the empty-state row also counts here: it falls through to the omnibar's prompt submit, the panel dismisses on focus loss, and the user never picked a tab — semantically a cancel.",
        "owners": ["tomasstrba"],
        "triggers": ["other"],
        "suffixes": ["daily_count"],
        "parameters": ["appVersion", "pixelSource", "channel"]
    },
    "m_mac_aichat_addressbar_submit_with_files": {
        "description": "Fired when user submits a prompt that includes one or more file (PDF etc.) attachments",
        "owners": ["tomasstrba"],
        "triggers": ["other"],
