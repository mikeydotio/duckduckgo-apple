{
    "m_mac_web_extension_installed": {
        "description": "Fires when a web extension is successfully installed.",
        "owners": ["tomasstrba"],
        "triggers": ["other"],
        "suffixes": ["daily_standard"],
        "parameters": ["appVersion", "pixelSource", "channel"]
    },
    "m_mac_web_extension_install_error": {
        "description": "Fires when a web extension installation fails.",
        "owners": ["tomasstrba"],
        "triggers": ["exception"],
        "suffixes": ["daily_standard"],
        "parameters": ["appVersion", "pixelSource", "errorCode", "errorDomain", "underlyingErrorCode", "underlyingErrorDomain"]
    },
    "m_mac_web_extension_uninstalled": {
        "description": "Fires when a web extension is successfully uninstalled.",
        "owners": ["tomasstrba"],
        "triggers": ["other"],
        "suffixes": ["daily_standard"],
        "parameters": ["appVersion", "pixelSource", "channel"]
    },
    "m_mac_web_extension_uninstall_error": {
        "description": "Fires when a web extension uninstallation fails.",
        "owners": ["tomasstrba"],
        "triggers": ["exception"],
        "suffixes": ["daily_standard"],
        "parameters": ["appVersion", "pixelSource", "errorCode", "errorDomain", "underlyingErrorCode", "underlyingErrorDomain"]
    },
    "m_mac_web_extension_uninstalled_all": {
        "description": "Fires when all web extensions are successfully uninstalled.",
        "owners": ["tomasstrba"],
        "triggers": ["other"],
        "suffixes": ["daily_standard"],
        "parameters": ["appVersion", "pixelSource", "channel"]
    },
    "m_mac_web_extension_uninstall_all_error": {
        "description": "Fires when uninstalling all web extensions fails (at least one extension failed to uninstall).",
        "owners": ["tomasstrba"],
        "triggers": ["exception"],
        "suffixes": ["daily_standard"],
        "parameters": ["appVersion", "pixelSource", "errorCode", "errorDomain", "underlyingErrorCode", "underlyingErrorDomain"]
    },
    "m_mac_web_extension_loaded": {
        "description": "Fires during app startup when installed web extensions are successfully loaded.",
        "owners": ["tomasstrba"],
        "triggers": ["other"],
        "suffixes": ["daily_standard"],
        "parameters": ["appVersion", "pixelSource", "channel"]
    },
    "m_mac_web_extension_load_error": {
        "description": "Fires during app startup when loading installed web extensions fails (at least one extension failed to load).",
        "owners": ["tomasstrba"],
        "triggers": ["exception"],
        "suffixes": ["daily_standard"],
        "parameters": ["appVersion", "pixelSource", "errorCode", "errorDomain", "underlyingErrorCode", "underlyingErrorDomain"]
    },
    "m_mac_web_extension_embedded_installed": {
        "description": "Fires when the embedded (bundled) web extension is successfully installed for the first time.",
        "owners": ["tomasstrba", "miasma13"],
        "triggers": ["other"],
        "suffixes": ["daily_standard"],
        "parameters": ["appVersion", "pixelSource", "channel"]
    },
    "m_mac_web_extension_embedded_upgraded": {
        "description": "Fires when the embedded (bundled) web extension is upgraded to a newer version.",
        "owners": ["tomasstrba", "miasma13"],
        "triggers": ["other"],
        "suffixes": ["daily_standard"],
        "parameters": [
            "appVersion",
            "pixelSource",
            {
                "key": "from_version",
                "type": "string",
                "description": "The previous version of the embedded extension before upgrade"
            },
            {
                "key": "to_version",
                "type": "string",
                "description": "The new version of the embedded extension after upgrade"
            },
            "channel"
        ]
    },
    "m_mac_web_extension_embedded_install_error": {
        "description": "Fires when installing or upgrading the embedded (bundled) web extension fails.",
        "owners": ["tomasstrba", "miasma13"],
        "triggers": ["exception"],
        "suffixes": ["daily_standard"],
        "parameters": ["appVersion", "pixelSource", "errorCode", "errorDomain", "underlyingErrorCode", "underlyingErrorDomain"]
    },
    "m_mac_web_extension_dark_reader_installed": {
        "description": "Fires when the Dark Reader web extension is successfully installed for the first time.",
        "owners": ["ayoy"],
        "triggers": ["other"],
        "suffixes": ["daily_standard"],
        "parameters": ["appVersion", "pixelSource"]
    },
    "m_mac_web_extension_dark_reader_upgraded": {
        "description": "Fires when the Dark Reader web extension is upgraded to a newer version.",
        "owners": ["ayoy"],
        "triggers": ["other"],
        "suffixes": ["daily_standard"],
        "parameters": [
            "appVersion",
            "pixelSource",
            {
                "key": "from_version",
                "type": "string",
                "description": "The previous version of the Dark Reader extension before upgrade"
            },
            {
                "key": "to_version",
                "type": "string",
                "description": "The new version of the Dark Reader extension after upgrade"
            }
        ]
    },
    "m_mac_web_extension_dark_reader_install_error": {
        "description": "Fires when installing or upgrading the Dark Reader web extension fails.",
        "owners": ["ayoy"],
        "triggers": ["exception"],
        "suffixes": ["daily_standard"],
        "parameters": ["appVersion", "pixelSource", "errorCode", "errorDomain", "underlyingErrorCode", "underlyingErrorDomain"]
    },
    "m_mac_web_extension_dark_reader_enabled": {
        "description": "Fires when the user enables force dark mode on websites.",
        "owners": ["ayoy"],
        "triggers": ["other"],
        "suffixes": ["daily_count"],
        "parameters": ["appVersion", "pixelSource"]
    },
    "m_mac_web_extension_dark_reader_disabled": {
        "description": "Fires when the user disables force dark mode on websites.",
        "owners": ["ayoy"],
        "triggers": ["other"],
        "suffixes": ["daily_count"],
        "parameters": ["appVersion", "pixelSource"]
    },
    "m_mac_web_extension_ad_blocking_installed": {
        "description": "Fires when the ad blocking web extension is successfully installed for the first time.",
        "owners": ["miasma13"],
        "triggers": ["other"],
        "suffixes": ["daily_standard"],
        "parameters": ["appVersion", "pixelSource", "channel"]
    },
    "m_mac_web_extension_ad_blocking_upgraded": {
        "description": "Fires when the ad blocking web extension is upgraded to a newer version.",
        "owners": ["miasma13"],
        "triggers": ["other"],
        "suffixes": ["daily_standard"],
        "parameters": [
            "appVersion",
            "pixelSource",
            {
                "key": "from_version",
                "type": "string",
                "description": "The previous version of the ad blocking extension before upgrade"
            },
            {
                "key": "to_version",
                "type": "string",
                "description": "The new version of the ad blocking extension after upgrade"
            },
            "channel"
        ]
    },
    "m_mac_web_extension_ad_blocking_install_error": {
        "description": "Fires when installing or upgrading the ad blocking web extension fails.",
        "owners": ["miasma13"],
        "triggers": ["exception"],
        "suffixes": ["daily_standard"],
        "parameters": ["appVersion", "pixelSource", "errorCode", "errorDomain", "underlyingErrorCode", "underlyingErrorDomain"]
    },
    "m_mac_web_extension_ad_blocking_enabled": {
        "description": "Fires when the user enables YouTube ad blocking in settings.",
        "owners": ["miasma13"],
        "triggers": ["other"],
        "suffixes": ["daily_count"],
        "parameters": ["appVersion", "pixelSource", "channel"]
    },
    "m_mac_web_extension_ad_blocking_disabled": {
        "description": "Fires when the user disables YouTube ad blocking in settings.",
        "owners": ["miasma13"],
        "triggers": ["other"],
        "suffixes": ["daily_count"],
        "parameters": ["appVersion", "pixelSource", "channel"]
    },
    "m_mac_web_extension_scriptlet_fetch_success": {
        "description": "Fires when scriptlets are successfully fetched from the server and saved to cache.",
        "owners": ["miasma13"],
        "triggers": ["other"],
        "suffixes": ["daily_standard"],
        "parameters": [
            "appVersion",
            "pixelSource",
            {
                "key": "extension_type",
                "type": "string",
                "description": "The web extension type the scriptlets belong to (e.g. com.duckduckgo.content-blocker-extension)"
            },
            {
                "key": "version",
                "type": "string",
                "description": "The version of the fetched scriptlets"
            },
            {
                "key": "count",
                "type": "string",
                "description": "The number of scriptlet files fetched"
            },
            "channel"
        ]
    },
    "m_mac_web_extension_scriptlet_fetch_error": {
        "description": "Fires when fetching or saving scriptlets fails (network error, empty response, storage failure).",
        "owners": ["miasma13"],
        "triggers": ["exception"],
        "suffixes": ["daily_standard"],
        "parameters": [
            "appVersion",
            "pixelSource",
            "errorCode",
            "errorDomain",
            "underlyingErrorCode",
            "underlyingErrorDomain",
            {
                "key": "extension_type",
                "type": "string",
                "description": "The web extension type the scriptlets belong to"
            }
        ]
    },
    "m_mac_web_extension_scriptlet_validation_error": {
        "description": "Fires when scriptlet signature validation fails in production, blocking the update.",
        "owners": ["miasma13"],
        "triggers": ["exception"],
        "suffixes": ["daily_standard"],
        "parameters": [
            "appVersion",
            "pixelSource",
            "errorCode",
            "errorDomain",
            "underlyingErrorCode",
            "underlyingErrorDomain",
            {
                "key": "extension_type",
                "type": "string",
                "description": "The web extension type the scriptlets belong to"
            }
        ]
    },
    "m_mac_web_extension_scriptlet_installed": {
        "description": "Fires when scriptlets are successfully installed into a web extension directory.",
        "owners": ["miasma13"],
        "triggers": ["other"],
        "suffixes": ["daily_standard"],
        "parameters": [
            "appVersion",
            "pixelSource",
            {
                "key": "extension_type",
                "type": "string",
                "description": "The web extension type the scriptlets were installed for"
            },
            {
                "key": "version",
                "type": "string",
                "description": "The version of the installed scriptlets"
            },
            "channel"
        ]
    },
    "m_mac_web_extension_scriptlet_install_error": {
        "description": "Fires when installing scriptlets into a web extension directory fails.",
        "owners": ["miasma13"],
        "triggers": ["exception"],
        "suffixes": ["daily_standard"],
        "parameters": [
            "appVersion",
            "pixelSource",
            "errorCode",
            "errorDomain",
            "underlyingErrorCode",
            "underlyingErrorDomain",
            {
                "key": "extension_type",
                "type": "string",
                "description": "The web extension type the scriptlets were being installed for"
            },
            "channel"
        ]
    },
    "m_mac_web_extension_daily_ad_blocking_state": {
        "description": "Fires once daily to report whether YouTube ad blocking is currently enabled (feature flag on and user opted in).",
        "owners": ["miasma13"],
        "triggers": ["other"],
        "suffixes": ["daily"],
        "parameters": [
            "appVersion",
            "pixelSource",
            {
                "key": "is_enabled",
                "type": "string",
                "description": "Whether ad blocking is currently enabled (true/false)"
            },
            {
                "key": "analytics_enabled",
                "type": "string",
                "description": "Whether the user opted in to anonymous breakage reports for YouTube ad blocking (true/false)"
            },
            "channel"
        ]
    },
    "m_mac_web_extension_adblocking_detected_ad_blocker": {
        "description": "Fires once daily when content-scope-scripts detects an ad blocker challenge while playing a YouTube video.",
        "owners": ["miasma13"],
        "triggers": ["other"],
        "suffixes": ["daily"],
        "parameters": [
            "appVersion",
            "pixelSource",
            {
                "key": "loginState",
                "type": "string",
                "enum": ["logged-in", "logged-out", "premium", "unknown"],
                "description": "User's YouTube login state at the time of detection"
            }
        ]
    },
    "m_mac_web_extension_adblocking_detected_playability_error": {
        "description": "Fires once daily when content-scope-scripts detects a YouTube playability error.",
        "owners": ["miasma13"],
        "triggers": ["other"],
        "suffixes": ["daily"],
        "parameters": [
            "appVersion",
            "pixelSource",
            {
                "key": "loginState",
                "type": "string",
                "enum": ["logged-in", "logged-out", "premium", "unknown"],
                "description": "User's YouTube login state at the time of detection"
            },
            "channel"
        ]
    },
    "m_mac_web_extension_adblocking_detected_video_ad": {
        "description": "Fires once daily when content-scope-scripts detects a YouTube video ad.",
        "owners": ["miasma13"],
        "triggers": ["other"],
        "suffixes": ["daily"],
        "parameters": [
            "appVersion",
            "pixelSource",
            {
                "key": "loginState",
                "type": "string",
                "enum": ["logged-in", "logged-out", "premium", "unknown"],
                "description": "User's YouTube login state at the time of detection"
            },
            "channel"
        ]
    },
    "m_mac_web_extension_adblocking_detected_static_ad": {
        "description": "Fires once daily when content-scope-scripts detects a YouTube static (non-video) ad.",
        "owners": ["miasma13"],
        "triggers": ["other"],
        "suffixes": ["daily"],
        "parameters": [
            "appVersion",
            "pixelSource",
            {
                "key": "loginState",
                "type": "string",
                "enum": ["logged-in", "logged-out", "premium", "unknown"],
                "description": "User's YouTube login state at the time of detection"
            },
            "channel"
        ]
    },
    "m_mac_web_extension_adblocking_detected_buffering": {
        "description": "Fires once daily when content-scope-scripts detects YouTube playback buffering.",
        "owners": ["miasma13"],
        "triggers": ["other"],
        "suffixes": ["daily"],
        "parameters": [
            "appVersion",
            "pixelSource",
            {
                "key": "loginState",
                "type": "string",
                "enum": ["logged-in", "logged-out", "premium", "unknown"],
                "description": "User's YouTube login state at the time of detection"
            },
            "channel"
        ]
    }
}
