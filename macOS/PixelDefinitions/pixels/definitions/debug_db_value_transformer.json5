{
    "m_mac_debug_db_value_transformer_registration_error": {
        "description": "Fired when the app fails to register Core Data value transformers during database initialization, just before a fatal error",
        "owners": ["samsymons"],
        "triggers": ["other"],
        "suffixes": ["daily_count"],
        "parameters": ["appVersion", "pixelSource", "errorCode", "errorDomain", "underlyingErrorCode", "underlyingErrorDomain"]
    }
}
