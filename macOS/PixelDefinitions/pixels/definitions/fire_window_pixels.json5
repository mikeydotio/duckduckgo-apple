// Fire Window configuration pixels
{
    "m_mac_fire_window_configuration_startup-fire-window_enabled": {
        "description": "Daily pixel fired when fire window is enabled for startup",
        "owners": ["jotaemepereira"],
        "triggers": ["scheduled"],
        "suffixes": ["daily"],
        "parameters": ["appVersion", "pixelSource"]
    },
    "m_mac_fire_window_configuration_startup-fire-window_disabled": {
        "description": "Daily pixel fired when fire window is disabled for startup",
        "owners": ["jotaemepereira"],
        "triggers": ["scheduled"],
        "suffixes": ["daily"],
        "parameters": ["appVersion", "pixelSource", "channel"]
    },
    "m_mac_fire_window_configuration_open-fire-window-by-default_enabled": {
        "description": "Daily pixel fired when open fire window by default preference is enabled",
        "owners": ["jotaemepereira"],
        "triggers": ["scheduled"],
        "suffixes": ["daily"],
        "parameters": ["appVersion", "pixelSource", "channel"]
    },
    "m_mac_fire_window_configuration_open-fire-window-by-default_disabled": {
        "description": "Daily pixel fired when open fire window by default preference is disabled",
        "owners": ["jotaemepereira"],
        "triggers": ["scheduled"],
        "suffixes": ["daily"],
        "parameters": ["appVersion", "pixelSource", "channel"]
    },
    "m_mac_fire_window_configuration_fire-animation_enabled": {
        "description": "Daily pixel fired when fire animation is enabled",
        "owners": ["jotaemepereira"],
        "triggers": ["scheduled"],
        "suffixes": ["daily"],
        "parameters": ["appVersion", "pixelSource", "channel"]
    },
    "m_mac_fire_window_configuration_fire-animation_disabled": {
        "description": "Daily pixel fired when fire animation is disabled",
        "owners": ["jotaemepereira"],
        "triggers": ["scheduled"],
        "suffixes": ["daily"],
        "parameters": ["appVersion", "pixelSource", "channel"]
    },
    "m_mac_fire_window_subscription_promo_displayed": {
        "description": "Fired when the subscription promo card is displayed on the Fire Window home page",
        "owners": ["hanyutang-sandra"],
        "triggers": ["other"],
        "parameters": ["appVersion", "pixelSource", "freeTrial"]
    },
    "m_mac_fire_window_subscription_promo_viewed": {
        "description": "Fired each time the user views the subscription promo card on the Fire Window home page, including repeat views when switching back to a tab with the promo",
        "owners": ["hanyutang-sandra"],
        "triggers": ["other"],
        "parameters": ["appVersion", "pixelSource", "freeTrial"]
    },
    "m_mac_fire_window_subscription_promo_cta_actioned": {
        "description": "Fired when the user taps the CTA button (Try for Free / Learn More) on the Fire Window subscription promo",
        "owners": ["hanyutang-sandra"],
        "triggers": ["other"],
        "parameters": ["appVersion", "pixelSource", "freeTrial"]
    },
    "m_mac_fire_window_subscription_promo_dismissed": {
        "description": "Fired when the user clicks the close (x) button on the Fire Window subscription promo",
        "owners": ["hanyutang-sandra"],
        "triggers": ["other"],
        "parameters": ["appVersion", "pixelSource", "freeTrial"]
    }
}
