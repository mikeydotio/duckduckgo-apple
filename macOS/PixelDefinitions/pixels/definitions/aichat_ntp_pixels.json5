{
    "m_mac_aichat_ntp_submit_with_image": {
        "description": "Fired when user submits a prompt that includes one or more image attachments from the New Tab Page omnibar",
        "owners": ["tomasstrba"],
        "triggers": ["other"],
        "suffixes": ["daily_count"],
        "parameters": [
            "appVersion",
            "pixelSource",
            {
                "key": "imageCount",
                "type": "integer",
                "description": "Number of images attached to the submitted prompt"
            }
        ]
    },
    "m_mac_aichat_ntp_model_selected": {
        "description": "Fired when user selects a model from the New Tab Page model picker",
        "owners": ["tomasstrba"],
        "triggers": ["other"],
        "suffixes": ["daily_count"],
        "parameters": ["appVersion", "pixelSource"]
    }
}
