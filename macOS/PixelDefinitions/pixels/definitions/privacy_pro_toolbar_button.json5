        "owners": ["hanyutang-sandra"],
        "triggers": ["other"],
        "suffixes": [],
        "parameters": ["appVersion", "pixelSource", "channel"]
    },

    "m_mac_store_subscription_toolbar_vpn_popover_expired_view_subscribe_button_clicked": {
