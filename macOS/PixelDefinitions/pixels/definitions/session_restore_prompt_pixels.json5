{
    "m_mac_unclean-exit_detected": {
        "description": "Fired when an unexpected app termination is detected on app launch.",
        "owners": ["rachelmcr"],
        "triggers": ["other"],
        "parameters": [
            "appVersion",
            "pixelSource",
            "channel",
            {
                "key": "restart-source-attribution",
                "description": "Why the unclean exit and subsequent restart occurred. app_update is Sparkle-only (confirmed pending update). unknown_with_app_update is App Store-only (version changed; exit cause undetermined).",
                "type": "string",
                "enum": ["crash", "app_update", "unknown_with_app_update", "unknown"]
            }
        ]
    },
    "m_mac_unclean-exit_popup_shown": {
        "description": "Fired when the unexpected app termination restore session popover is shown to the user",
        "owners": ["rachelmcr"],
        "triggers": ["other"],
        "parameters": ["appVersion", "pixelSource", "channel"]
    },
    "m_mac_unclean-exit_popup_dismissed_without-restore": {
        "description": "Fired when user dismisses the unexpected app termination popover without choosing to restore tabs",
        "owners": ["rachelmcr"],
        "triggers": ["other"],
        "parameters": ["appVersion", "pixelSource", "channel"]
    },
    "m_mac_unclean-exit_popup_dismissed_with-restore": {
        "description": "Fired when user dismisses the unexpected app termination popover and chooses to restore tabs",
        "owners": ["rachelmcr"],
        "triggers": ["other"],
        "parameters": ["appVersion", "pixelSource", "channel"]
    },
    "m_mac_unclean-exit_popup_browser-closed": {
        "description": "Fired when the browser is closed while the unexpected app termination popover is still open",
        "owners": ["rachelmcr"],
        "triggers": ["other"],
        "parameters": ["appVersion", "pixelSource", "channel"]
    },
    "m_mac_debug_unclean-exit_flag-read-failed": {
        "description": "Fired when reading the appDidTerminateAsExpected flag from KeyValueStore fails during unclean exit detection",
        "owners": ["rachelmcr"],
        "triggers": ["other"],
        "parameters": ["appVersion", "pixelSource", "channel", "errorCode", "errorDomain", "underlyingErrorCode", "underlyingErrorDomain"]
    },
    "m_mac_debug_unclean-exit_flag-write-failed": {
        "description": "Fired when writing the appDidTerminateAsExpected flag to KeyValueStore fails during clean quit or launch arming",
        "owners": ["rachelmcr"],
        "triggers": ["other"],
        "parameters": ["appVersion", "pixelSource", "channel", "errorCode", "errorDomain", "underlyingErrorCode", "underlyingErrorDomain"]
    }
}
