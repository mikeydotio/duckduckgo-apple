// This file defines commonly used params - this does NOT mean they are added by default
// In your pixel definitions, you can reference these params by their key
// See TEMPLATE.json for an example
{
    "appVersion": {
        "key": "appVersion",
        "type": "string",
        "description": "",
        "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
        "examples": ["1.146.0"]
    },
    "atb": {
        "key": "atb",
        "type": "string",
        "pattern": "v[0-9]{1,3}-[0-7]([a-z]{2})?",
        "description": "Add to browser value, corresponding to the users install week and day"
    },
    "pixelSource": {
        "key": "pixelSource",
        "type": "string",
        "description": "The channel the user is on",
        "enum": [
            "browser-dmg",
            "browser-appstore",
            "vpnAgent",
            "vpnAgentAppStore",
            "vpnAppExtension",
            "vpnSystemExtension",
            "vpnSystemExtensionAppStore",
            "vpnProxyExtension",
            "dbpBackgroundAgent"
        ]
    },
    "channel": {
        "key": "channel",
        "type": "string",
        "description": "Identifies non-production pixels. 'canary' for internal users; 'dev' for alpha/review builds. Omitted for production builds.",
        "enum": ["canary", "dev"]
    },
    "errorDomain": {
        "key": "d",
        "type": "string",
        "description": "String constant representing an Apple-defined error domain (e.g., WebKitErrorDomain, NSURLErrorDomain) or VPN-specific error domain. Not free-form strings, but too large and frequently changing a set to enumerate",
        "examples": ["WebKitErrorDomain", "NSURLErrorDomain", "SKErrorDomain"]
    },
    "errorCode": {
        "key": "e",
        "type": "number",
        "description": "NSError code"
    },
    "keychainErrorCode": {
        "key": "keychain_error_code",
        "type": "string",
        "description": "OSStatus code returned by the Keychain when reading or writing the encryption key failed"
    },
    "fromExtension": {
        "key": "fromExtension",
        "description": "0 when fired from UserScript (web extensions available but autoconsent extension not loaded), 1 when fired from the web extension",
        "type": "integer",
        "enum": [0, 1]
    },
    "themeName": {
        "key": "themeName",
        "enum": ["default", "coolGray", "desert", "green", "orange", "rose", "slateBlue", "violet"],
        "description": "The name of the active Theme"
    },
    "themeChangeSource": {
        "key": "themeChangeSource",
        "enum": ["new-tab-page", "settings"],
        "description": "Interface from which the Theme Name or Appearance were updated"
    },
    "underlyingErrorCode": {
        "keyPattern": "^ue[0-9]?$",
        "type": "number",
        "description": "Underlying NSError code"
    },
    "underlyingErrorDomain": {
        "keyPattern": "^ud[0-9]?$",
        "type": "string",
        "description": "String constant representing an Apple-defined underlying error domain (e.g., WebKitErrorDomain, NSURLErrorDomain) or VPN-specific underlying error domain. Not free-form strings, but too large and frequently changing a set to enumerate",
        "examples": ["WebKitErrorDomain", "NSURLErrorDomain", "SKErrorDomain"]
    },
    "wideEventAppName": {
        "key": "app.name",
        "type": "string",
        "description": "The name of the app sending the pixel"
    },
    "wideEventAppVersion": {
        "key": "app.version",
        "type": "string",
        "description": "The version of the app sending the pixel"
    },
    "wideEventPlatform": {
        "key": "global.platform",
        "type": "string",
        "description": "The name of the platform that the app is running on",
        "enum": ["macOS"]
    },
    "wideEventType": {
        "key": "global.type",
        "type": "string",
        "description": "The type of software sending the wide pixel",
        "enum": ["app"]
    },
    "wideEventSampleRate": {
        "key": "global.sample_rate",
        "type": "number",
        "description": "Sample rate for this pixel, between 0 and 1"
    },
    "wideEventMetaVersion": {
        "key": "meta.version",
        "type": "string",
        "description": "Schema version of the wide event (MAJOR.MINOR.PATCH format)",
        "pattern": "^[1-9]\\d*\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$"
    },
    "wideEventIsFirstDailyOccurrence": {
        "key": "global.is_first_daily_occurrence",
        "type": "boolean",
        "description": "Whether this is the first occurrence of this wide event today. Only included when true."
    },
    "wideEventFeatureStatus": {
        "key": "feature.status",
        "type": "string",
        "description": "Final status of the wide event flow",
        "enum": ["SUCCESS", "FAILURE", "CANCELLED", "UNKNOWN"]
    },
    "wideEventFeatureStatusReason": {
        "key": "feature.data.ext.status_reason",
        "type": "string",
        "description": "Optional reason accompanying the feature status"
    },
    "wideEventErrorDomain": {
        "key": "feature.data.ext.error.domain",
        "type": "string",
        "description": "Error domain for the failure, when applicable, e.g. SKErrorDomain"
    },
    "wideEventErrorCode": {
        "key": "feature.data.ext.error.code",
        "type": "integer",
        "description": "Error code for the failure, when applicable"
    },
    "wideEventUnderlyingErrorDomain": {
        "keyPattern": "feature\\.data\\.ext\\.error\\.underlying_domain[0-9]?",
        "type": "string",
        "description": "Underlying error domain (supports optional numeric index for nested errors)"
    },
    "wideEventUnderlyingErrorCode": {
        "keyPattern": "feature\\.data\\.ext\\.error\\.underlying_code[0-9]?",
        "type": "integer",
        "description": "Underlying error code (supports optional numeric index for nested errors)"
    },
    "duration": {
        "key": "duration",
        "type": "integer",
        "description": "Duration in milliseconds",
        "examples": [1500, 3200]
    },
    "navigation_type": {
        "key": "navigation_type",
        "type": "string",
        "description": "Type of navigation that triggered the loading",
        "enum": [
            "linkActivated",
            "formSubmitted",
            "formResubmitted",
            "backForward",
            "reload",
            "redirect",
            "sessionRestoration",
            "alternateHtmlLoad",
            "sameDocumentNavigation",
            "other",
            "custom.userEnteredUrl",
            "custom.loadedByStateRestoration",
            "custom.appOpenUrl",
            "custom.historyEntry",
            "custom.bookmark",
            "custom.ui",
            "custom.link",
            "custom.webViewUpdated",
            "custom.userRequestedPageDownload",
            "custom.unknown"
        ]
    },
    "dbpDataBroker": {
        "key": "data_broker",
        "type": "string",
        "description": "Name of the data broker involved in the opt-out attempt or action"
    },
    "dbpParentBroker": {
        "key": "parent",
        "type": "string",
        "description": "Parent data broker of the entity targeted by the opt-out attempt"
    },
    "dbpAttemptId": {
        "key": "attempt_id",
        "type": "string",
        "description": "Client-generated identifier of the opt-out attempt"
    },
    "dbpBrokerVersion": {
        "key": "broker_version",
        "type": "string",
        "description": "Version of the broker JSON file used for the flow"
    },
    "dbpIsAuthenticated": {
        "key": "isAuthenticated",
        "type": "string",
        "description": "Whether the user is authenticated",
        "enum": ["true", "false"]
    },
    "dbpIsFreeScan": {
        "key": "free_scan",
        "type": "string",
        "description": "Whether this is a free (unauthenticated) scan",
        "enum": ["true", "false"]
    },
    "dbpStageDuration": {
        "key": "duration",
        "type": "integer",
        "description": "Stage duration in milliseconds"
    },
    "dbpStageTries": {
        "key": "tries",
        "type": "string",
        "description": "Number of tries it took to complete the stage"
    },
    "dbpActionId": {
        "key": "action_id",
        "type": "string",
        "description": "Identifier of the broker action executed during the broker flow"
    },
    "dbpActionType": {
        "key": "action_type",
        "type": "string",
        "description": "Type of action executed during the broker flow",
        "enum": [
            "extract",
            "navigate",
            "fillForm",
            "click",
            "expectation",
            "emailConfirmation",
            "generateEmail",
            "getEmailData",
            "getCaptchaInfo",
            "solveCaptcha",
            "condition",
            "unknown"
        ]
    },
    "dbpActionDuration": {
        "key": "duration",
        "type": "integer",
        "description": "Duration of the broker action execution in milliseconds"
    },
    "dbpActionTries": {
        "key": "tries",
        "type": "integer",
        "description": "Number of tries it took for the broker action to complete"
    },
    "dbpAttemptDuration": {
        "key": "duration",
        "type": "number",
        "description": "Total duration of the opt-out attempt in milliseconds"
    },
    "dbpConfirmationAttemptNumber": {
        "key": "attempt_number",
        "type": "integer",
        "description": "Confirmation attempt ordinal (1..3)"
    },
    "dbpFeatureDataBrokerVersion": {
        "key": "feature.data.ext.data_broker_version",
        "type": "string",
        "description": "Version of the broker JSON file reported via wide pixels"
    },
    "vpnSubscriptionActive": {
        "key": "vpnSubscriptionActive",
        "type": "string",
        "description": "Whether the VPN subscription is active",
        "enum": ["true", "false", "no_subscription"]
    },
    "vpnNotificationObjectClass": {
        "key": "notificationObjectClass",
        "type": "string",
        "description": "Class name of the object that originated the subscription notification"
    },
    "vpnLatencyLocation": {
        "key": "location",
        "type": "string",
        "description": "Location selection for the VPN latency test",
        "enum": ["nearest", "custom"]
    },
    "connectionAttemptSource": {
        "key": "source",
        "type": "string",
        "description": "The origin of a VPN connection attempt",
        "enum": ["start", "rekey", "serverChange", "locationChange", "adapterRestart", "failureRecovery", "serverMigration"]
    },
    "locale": {
        "key": "locale",
        "type": "string",
        "description": "User locale",
        "examples": ["en-US", "hu-HU"]
    },
    "freeTrial": {
        "key": "free_trial",
        "type": "boolean",
        "description": "Whether the user is eligible for a free trial"
    },
    "subscribed": {
        "key": "subscribed",
        "type": "boolean",
        "description": "Whether the user has an active subscription at the time the pixel fires."
    },
    "subscriptionEntryStatus": {
        "key": "status",
        "type": "string",
        "description": "Visual state of the subscription entry-point promo at impression time. Indicates which badge variant the user saw on a non-subscriber surface (App Menu, Preferences).",
        "enum": ["churned", "free-eligible", "free-ineligible"]
    },
    "subscriptionFunnelOrigin": {
        "key": "origin",
        "type": "string",
        "description": "Funnel that led the user to a subscription pixel — encodes the entry-point and platform. Values follow the convention `funnel_<entry-point>_<platform>[_<modifier>]`.",
        "pattern": "^funnel_",
        "examples": ["funnel_appmenu_macos", "funnel_appsettings_macos", "funnel_freescan_macos", "funnel_appmenu_macos_winback"]
    },
    "onboardingEventType": {
        "key": "e",
        "type": "string",
        "description": "Event type to classify what happened at each onboarding step",
        "enum": ["shown", "clicked", "confirmed"]
    },
    "onboardingClickedValue": {
        "key": "value",
        "type": "string",
        "description": "Whether the user clicked the primary CTA or skipped/closed the onboarding step",
        "enum": ["engage", "dismiss"]
    },
    "onboardingInstallType": {
        "key": "it",
        "type": "string",
        "description": "Install type to distinguish between first-time installs and reinstalls during onboarding",
        "enum": ["new", "reinstall"]
    },
    "onboardingDaysSinceInstall": {
        "key": "d",
        "type": "integer",
        "description": "Days since install when the value is between 0 and 28 inclusive during onboarding"
    },
    "nextStepsDaysSinceInstall": {
        "key": "daysSinceInstall",
        "type": "integer",
        "description": "Days since app install (in buckets of 0, 1, 2-3, 4+)",
        "enum": [0, 1, 2, 4]
    },
    "nextStepsActiveUsageDays": {
        "key": "nextStepsActiveUsageDays",
        "type": "integer",
        "description": "Number of days the New Tab Page has been opened with Next Steps cards visible",
        "enum": [0, 1, 2, 3, 4, 6, 9, 14]
    },
    "ntpImpressionCount": {
        "key": "ntpImpressionCount",
        "type": "integer",
        "description": "Number of times the New Tab Page has been opened (newTabPageWebViewDidAppear)",
        "enum": [1, 2, 3, 4, 5, 6, 7, 8, 10, 15, 25, 50]
    },
    "nextStepsCardImpressionCount": {
        "key": "cardImpressionCount",
        "type": "integer",
        "description": "Number of times a Next Steps card was shown (appeared at the top of the Next Steps card stack)",
        "maximum": 10
    }
}
